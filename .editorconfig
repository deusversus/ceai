root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,props,targets,xml,xshd}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Namespace preferences
csharp_style_namespace_declarations = file_scoped:suggestion

# var preferences
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Expression-level preferences
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion

# Pattern matching preferences
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# Null-checking preferences
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

# Code quality
dotnet_diagnostic.CA1031.severity = suggestion  # Do not catch general exception types
dotnet_diagnostic.CA1848.severity = suggestion  # Use LoggerMessage delegates for perf
dotnet_diagnostic.CA2007.severity = none        # Do not directly await Task (WPF handles SyncContext)
dotnet_diagnostic.CA1816.severity = suggestion  # Dispose pattern
dotnet_diagnostic.IDE0005.severity = warning    # Remove unnecessary usings

# Suppressed — false positives or inapplicable for this project
dotnet_diagnostic.CA1707.severity = none        # Underscores in identifiers — CommunityToolkit.Mvvm [ObservableProperty] convention
dotnet_diagnostic.CA1725.severity = none        # Parameter names should match base — not actionable when implementing interfaces
dotnet_diagnostic.CA1720.severity = none        # Identifier contains type name — too pedantic for domain models
dotnet_diagnostic.CA1716.severity = none        # Identifiers should not match keywords — too pedantic
dotnet_diagnostic.CA1000.severity = none        # Static members on generic types — valid pattern (factory methods)
