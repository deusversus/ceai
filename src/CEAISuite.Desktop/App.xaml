<Application x:Class="CEAISuite.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme loaded at startup; ThemeManager swaps at runtime -->
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
                <!-- Shared control styles (must come after theme so DynamicResource resolves) -->
                <ResourceDictionary Source="Themes/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
