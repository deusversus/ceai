<UserControl x:Class="CEAISuite.Desktop.Controls.DataInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PanelBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="6,4">
            <TextBlock Text="Data Inspector" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center" />
            <CheckBox Content="Big Endian" Margin="12,0,0,0" VerticalAlignment="Center"
                      Foreground="{DynamicResource PrimaryForeground}"
                      IsChecked="{Binding IsBigEndian}" />
        </StackPanel>

        <!-- Type list -->
        <ListView Grid.Row="1" ItemsSource="{Binding Entries}" BorderThickness="0"
                  Background="Transparent"
                  Foreground="{DynamicResource PrimaryForeground}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Type" Width="60"
                                    DisplayMemberBinding="{Binding TypeName}" />
                    <GridViewColumn Header="Value" Width="140"
                                    DisplayMemberBinding="{Binding Value}" />
                    <GridViewColumn Header="Hex" Width="100"
                                    DisplayMemberBinding="{Binding HexValue}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
