<Window x:Class="CEAISuite.Desktop.LoadSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Session" Width="480" Height="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource CaptionCloseButton}" Click="CaptionClose_Click">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" Data="M 0,0 L 10,10 M 10,0 L 0,10" Width="10" Height="10" Stretch="Uniform" />
                </Button>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TitleBarForeground}" />
            </DockPanel>
        </Border>
    <DockPanel Grid.Row="1" Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Load" Padding="16,6" IsDefault="True"
                    Click="Load_Click" />
            <Button Content="Delete" Padding="16,6" Margin="8,0,0,0"
                    Foreground="OrangeRed" Click="Delete_Click" />
            <Button Content="Cancel" Padding="16,6" Margin="8,0,0,0"
                    IsCancel="True" Click="Cancel_Click" />
        </StackPanel>
        <ListBox x:Name="SessionListBox" />
    </DockPanel>
    </Grid>
</Window>
