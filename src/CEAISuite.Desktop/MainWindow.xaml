<Window x:Class="CEAISuite.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CE AI Suite"
        Height="860"
        Width="1500"
        MinHeight="700"
        MinWidth="1100">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Padding="10,6" Margin="0,0,8,0" Click="SaveSession" Content="💾 Save Session" />
                <Button Padding="10,6" Click="LoadSession" Content="📂 Load Session" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="{Binding ProductName}"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding Summary}"
                           TextWrapping="Wrap"
                           Foreground="#444444" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,16"
                Padding="12"
                Background="#F5F7FA"
                BorderBrush="#D0D7DE"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Default profile" />
                <TextBlock Margin="0,6,0,0" Text="{Binding DefaultProfile.Name}" />
                <TextBlock Text="{Binding DefaultProfile.TargetPlatform}" Foreground="#555555" />
                <TextBlock Text="{Binding DefaultProfile.TargetProcess}" Foreground="#555555" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Running processes" Margin="0,0,12,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#555555" />
                        <Button Margin="0,8,0,0"
                                Padding="10,6"
                                HorizontalAlignment="Left"
                                Click="InspectSelectedProcess"
                                Content="Inspect selected process" />
                    </StackPanel>
                    <ListView x:Name="RunningProcessesList" ItemsSource="{Binding RunningProcesses}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Text="{Binding Id, StringFormat=PID {0}}" Foreground="#555555" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Padding="6,2"
                                            Background="#EDEFF2"
                                            CornerRadius="4">
                                        <TextBlock FontSize="11" Text="{Binding Architecture}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </GroupBox>

            <ScrollViewer Grid.Column="1" Margin="0,0,12,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="Process inspection">
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding CurrentInspection.ProcessName, TargetNullValue=No process selected}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#555555"
                                       Text="{Binding CurrentInspection.Architecture, TargetNullValue=Pick a running process to inspect modules and memory.}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding CurrentInspection.StatusMessage}" 
                                       TextWrapping="Wrap" />

                            <Border Margin="0,12,0,12"
                                    Padding="10"
                                    Background="#F5F7FA"
                                    BorderBrush="#D0D7DE"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Manual memory editor" />
                                    <TextBlock Margin="0,6,0,0" Text="Address" />
                                    <TextBox x:Name="AddressTextBox"
                                             Margin="0,4,0,0"
                                             Text="0x0" />
                                    <TextBlock Margin="0,10,0,0" Text="Type" />
                                    <ComboBox x:Name="TypeComboBox"
                                              Margin="0,4,0,0"
                                              Loaded="OnTypeComboBoxLoaded" />
                                    <TextBlock Margin="0,10,0,0" Text="Value" />
                                    <TextBox x:Name="ValueTextBox"
                                             Margin="0,4,0,0"
                                             Text="0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Padding="10,6"
                                                Margin="0,0,8,0"
                                                Click="ReadAddress"
                                                Content="Read" />
                                        <Button Padding="10,6"
                                                Margin="0,0,8,0"
                                                Click="WriteAddress"
                                                Content="Write" />
                                        <Button Padding="10,6"
                                                Click="AddManualToTable"
                                                Content="Add to table" />
                                    </StackPanel>

                                    <TextBlock Margin="0,12,0,0"
                                               FontWeight="SemiBold"
                                               Text="Last probe" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding CurrentInspection.ManualProbe.Address, TargetNullValue=No manual probe yet}" />
                                    <TextBlock Text="{Binding CurrentInspection.ManualProbe.DataType, StringFormat=Type: {0}}" />
                                    <TextBlock Text="{Binding CurrentInspection.ManualProbe.DisplayValue, StringFormat=Value: {0}}" />
                                    <TextBlock FontFamily="Consolas"
                                               Text="{Binding CurrentInspection.ManualProbe.HexBytes}" 
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               FontWeight="SemiBold"
                                               Text="Last write" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding CurrentInspection.LastWriteMessage, TargetNullValue=No writes issued in this session.}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,0,0,8"
                                       FontWeight="SemiBold"
                                       Text="Modules" />
                            <ListView ItemsSource="{Binding CurrentInspection.Modules}" MaxHeight="200">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock Foreground="#555555" Text="{Binding BaseAddress}" />
                                            <TextBlock Text="{Binding Size}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Disassembly">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBox x:Name="DisasmAddressTextBox"
                                         Width="180"
                                         Margin="0,0,8,0"
                                         Text="0x0" />
                                <Button Padding="10,6"
                                        Click="DisassembleAtAddress"
                                        Content="Disassemble" />
                            </StackPanel>
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="#555555"
                                       Text="{Binding Disassembly.Summary, TargetNullValue=Enter an address and click Disassemble.}" />
                            <ListView ItemsSource="{Binding Disassembly.Lines}"
                                      MaxHeight="300"
                                      FontFamily="Consolas"
                                      FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Address" Width="130"
                                                        DisplayMemberBinding="{Binding Address}" />
                                        <GridViewColumn Header="Bytes" Width="140"
                                                        DisplayMemberBinding="{Binding HexBytes}" />
                                        <GridViewColumn Header="Instruction" Width="80"
                                                        DisplayMemberBinding="{Binding Mnemonic}" />
                                        <GridViewColumn Header="Operands" Width="200"
                                                        DisplayMemberBinding="{Binding Operands}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Breakpoints" Margin="0,8,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBox x:Name="BpAddressTextBox"
                                         Width="150"
                                         Margin="0,0,8,0"
                                         Text="0x0" />
                                <ComboBox x:Name="BpTypeComboBox"
                                          Width="130"
                                          Margin="0,0,8,0"
                                          Loaded="OnBpTypeComboBoxLoaded" />
                                <Button Padding="10,6"
                                        Click="SetBreakpoint"
                                        Content="Set BP" />
                            </StackPanel>
                            <TextBlock Margin="0,0,0,6"
                                       Foreground="#555555"
                                       Text="{Binding BreakpointStatus, TargetNullValue=No breakpoints set. Attach to a process first.}" />
                            <ListView x:Name="BreakpointListView"
                                      MaxHeight="180"
                                      FontFamily="Consolas"
                                      FontSize="12">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" Width="100"
                                                        DisplayMemberBinding="{Binding Id}" />
                                        <GridViewColumn Header="Address" Width="120"
                                                        DisplayMemberBinding="{Binding Address}" />
                                        <GridViewColumn Header="Type" Width="90"
                                                        DisplayMemberBinding="{Binding Type}" />
                                        <GridViewColumn Header="Hits" Width="50"
                                                        DisplayMemberBinding="{Binding HitCount}" />
                                        <GridViewColumn Header="Status" Width="70"
                                                        DisplayMemberBinding="{Binding Status}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Padding="10,6"
                                        Margin="0,0,8,0"
                                        Click="RemoveBreakpoint"
                                        Content="Remove" />
                                <Button Padding="10,6"
                                        Margin="0,0,8,0"
                                        Click="RefreshBreakpoints"
                                        Content="Refresh" />
                                <Button Padding="10,6"
                                        Click="ViewHitLog"
                                        Content="View hits" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <GroupBox Grid.Column="2" Header="Memory scanner">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Margin="0,0,0,6" Text="Scan type" />
                        <ComboBox x:Name="ScanTypeComboBox"
                                  Margin="0,0,0,8"
                                  Loaded="OnScanTypeComboBoxLoaded" />
                        <TextBlock Margin="0,0,0,6" Text="Data type" />
                        <ComboBox x:Name="ScanDataTypeComboBox"
                                  Margin="0,0,0,8"
                                  Loaded="OnScanDataTypeComboBoxLoaded" />
                        <TextBlock Margin="0,0,0,6" Text="Value" />
                        <TextBox x:Name="ScanValueTextBox"
                                 Margin="0,0,0,8"
                                 Text="" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Padding="10,6"
                                    Margin="0,0,8,0"
                                    Click="StartNewScan"
                                    Content="New scan" />
                            <Button Padding="10,6"
                                    Margin="0,0,8,0"
                                    Click="RefineScan"
                                    Content="Next scan" />
                            <Button Padding="10,6"
                                    Click="ResetScan"
                                    Content="Reset" />
                        </StackPanel>

                        <Border Padding="8"
                                Background="#F5F7FA"
                                BorderBrush="#D0D7DE"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding ScanStatus, TargetNullValue=No scan active}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#555555"
                                           Text="{Binding ScanDetails}" />
                            </StackPanel>
                        </Border>

                        <Button Padding="10,6"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Click="AddSelectedScanResultToTable"
                                Content="Add selected to table" />
                    </StackPanel>

                    <ListView x:Name="ScanResultsList" ItemsSource="{Binding ScanResults}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Address" Width="130"
                                                DisplayMemberBinding="{Binding Address}" />
                                <GridViewColumn Header="Value" Width="100"
                                                DisplayMemberBinding="{Binding CurrentValue}" />
                                <GridViewColumn Header="Previous" Width="100"
                                                DisplayMemberBinding="{Binding PreviousValue}" />
                                <GridViewColumn Header="Hex" Width="100"
                                                DisplayMemberBinding="{Binding HexBytes}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </GroupBox>

            <!-- Column 3: AI Operator pane -->
            <GroupBox Grid.Column="3" Header="AI Operator" Margin="12,0,0,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AiChatInputTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,8,0"
                                     Padding="6,4"
                                     KeyDown="OnAiChatKeyDown" />
                            <Button Grid.Column="1"
                                    Padding="12,6"
                                    Click="SendAiMessage"
                                    Content="Send" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Padding="8,4"
                                    Margin="0,0,8,0"
                                    Click="ClearAiChat"
                                    Content="Clear chat" />
                            <TextBlock x:Name="AiStatusText"
                                       VerticalAlignment="Center"
                                       Foreground="#888"
                                       Text="Ready" />
                        </StackPanel>
                    </StackPanel>
                    <ScrollViewer x:Name="AiChatScrollViewer" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AiChatList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6"
                                            Margin="0,0,0,4"
                                            CornerRadius="6"
                                            Background="{Binding Background}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       FontSize="10"
                                                       Foreground="#666"
                                                       Text="{Binding RoleLabel}" />
                                            <TextBlock TextWrapping="Wrap"
                                                       Text="{Binding Content}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="3" Header="Address table" Margin="0,12,0,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Padding="10,6"
                            Margin="0,0,8,0"
                            Click="RefreshAddressTable"
                            Content="Refresh all" />
                    <Button Padding="10,6"
                            Margin="0,0,8,0"
                            Click="RemoveSelectedAddress"
                            Content="Remove selected" />
                    <Button Padding="10,6"
                            Margin="0,0,8,0"
                            Click="ToggleLockAddress"
                            Content="Toggle lock" />
                    <Button Padding="10,6"
                            Margin="0,0,8,0"
                            Click="ExportAddressTable"
                            Content="Export JSON" />
                    <Button Padding="10,6"
                            Margin="0,0,8,0"
                            Click="ImportAddressTable"
                            Content="Import JSON" />
                    <Button Padding="10,6"
                            Margin="0,0,8,0"
                            Click="GenerateTrainerScript"
                            Content="Generate trainer" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="#555555"
                               Text="{Binding AddressTableStatus, TargetNullValue=No addresses saved}" />
                </StackPanel>
                <ListView x:Name="AddressTableList" ItemsSource="{Binding AddressTableEntries}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Label" Width="140"
                                            DisplayMemberBinding="{Binding Label}" />
                            <GridViewColumn Header="Address" Width="130"
                                            DisplayMemberBinding="{Binding Address}" />
                            <GridViewColumn Header="Type" Width="70"
                                            DisplayMemberBinding="{Binding DataType}" />
                            <GridViewColumn Header="Value" Width="110"
                                            DisplayMemberBinding="{Binding CurrentValue}" />
                            <GridViewColumn Header="Previous" Width="110"
                                            DisplayMemberBinding="{Binding PreviousValue}" />
                            <GridViewColumn Header="Locked" Width="60"
                                            DisplayMemberBinding="{Binding IsLocked}" />
                            <GridViewColumn Header="Lock value" Width="100"
                                            DisplayMemberBinding="{Binding LockedValue}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
