<Window x:Class="CEAISuite.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CEAISuite.Desktop"
        mc:Ignorable="d"
        Title="CE AI Suite"
        Height="860"
        Width="1500"
        MinHeight="700"
        MinWidth="1100"
        Background="#1E1E1E">
    <Window.Resources>
        <local:StringToBrushConverter x:Key="BrushConv" />

        <!-- System color overrides for selection highlights -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#264F78" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#CCCCCC" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#264F78" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#CCCCCC" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#264F78" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="CaretBrush" Value="#CCCCCC" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#0E639C" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1177BB" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#094771" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3C3C3C" />
                    <Setter Property="Foreground" Value="#808080" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4E4E4E" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#555555" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264F78" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC" />
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Margin" Value="0,2" />
        </Style>

        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="#3C3C3C" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007ACC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="#808080" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" MinHeight="200" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" MinHeight="150" />
        </Grid.RowDefinitions>

        <!-- Row 0: Menu Bar -->
        <Menu x:Name="MainMenu" Grid.Row="0" Background="#2D2D2D" Foreground="#CCCCCC"
              FontSize="12" Padding="2,1">
            <MenuItem Header="_File">
                <MenuItem Header="_Save Session" Click="SaveSession" InputGestureText="Ctrl+S" />
                <MenuItem Header="_Load Session" Click="LoadSession" />
                <Separator />
                <MenuItem Header="Load Cheat _Table (.CT)" Click="LoadCheatTable" />
                <MenuItem Header="Save Cheat Table (.CT)" Click="SaveCheatTable" />
                <Separator />
                <MenuItem Header="E_xit" Click="ExitApp" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Click="MenuUndo" InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo" Click="MenuRedo" InputGestureText="Ctrl+Y" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="MenuBarToggleItem" Header="Hide _Menu Bar" Click="ToggleMenuBar"
                          InputGestureText="Alt" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Memory Browser" Click="OpenMemoryBrowser" />
            </MenuItem>
            <MenuItem Header="_Settings" Click="OpenSettings" />
            <MenuItem Header="_Help">
                <MenuItem Header="_About CE AI Suite" Click="ShowAbout" />
            </MenuItem>
        </Menu>

        <!-- Row 1: Compact status/profile bar -->
        <Border Grid.Row="1" Background="#2D2D2D" BorderBrush="#3C3C3C"
                BorderThickness="0,0,0,1" Padding="10,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding ProductName}"
                           FontWeight="SemiBold" FontSize="13" Foreground="#CCCCCC" />
                <TextBlock DockPanel.Dock="Left" Text=" | " Foreground="#3C3C3C" Margin="6,0" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding Summary}"
                           Foreground="#808080" TextTrimming="CharacterEllipsis" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding DefaultProfile.Name}" Foreground="#569CD6" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding DefaultProfile.TargetPlatform}" Foreground="#808080" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding DefaultProfile.TargetProcess}" Foreground="#808080" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 2: Main panels (left sidebar | center | right sidebar) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR: Process List -->
            <DockPanel Grid.Column="0" Background="#252526">
                <TextBlock DockPanel.Dock="Top" Text="PROCESSES" FontSize="11" FontWeight="SemiBold"
                           Foreground="#808080" Margin="8,8,8,4" />
                <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" Foreground="#808080" FontSize="11" Margin="8,0,8,4" />
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,6">
                    <Button Padding="8,3" Margin="0,0,6,0" Click="InspectSelectedProcess"
                            Content="Inspect" FontSize="11" />
                    <Button Padding="8,3" Click="RefreshProcessList" Content="Refresh"
                            FontSize="11" Style="{StaticResource ToolbarButton}" />
                </StackPanel>
                <ListView x:Name="RunningProcessesList" ItemsSource="{Binding RunningProcesses}"
                          Background="#252526" BorderThickness="0"
                          PreviewMouseLeftButtonDown="ProcessList_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="ProcessList_PreviewMouseMove">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" FontSize="12" />
                                    <TextBlock Text="{Binding Id, StringFormat=PID {0}}" Foreground="#808080" FontSize="11" />
                                </StackPanel>
                                <Border Grid.Column="1" Padding="4,1" Background="#3C3C3C" CornerRadius="3">
                                    <TextBlock FontSize="10" Text="{Binding Architecture}" Foreground="#808080" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>

            <!-- Vertical GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" ResizeDirection="Columns" />

            <!-- CENTER AREA -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" MinHeight="100" />
                </Grid.RowDefinitions>

                <!-- Center Top: Inspection, Memory Editor, Disassembly, Breakpoints -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="#252526">
                    <StackPanel Margin="8">
                        <!-- Process Inspection -->
                        <TextBlock Text="PROCESS INSPECTION" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#808080" Margin="0,0,0,6" />
                        <TextBlock FontSize="15" FontWeight="SemiBold"
                                   Text="{Binding CurrentInspection.ProcessName, TargetNullValue=No process selected}" />
                        <TextBlock Margin="0,4,0,0" Foreground="#808080"
                                   Text="{Binding CurrentInspection.Architecture, TargetNullValue=Pick a running process to inspect modules and memory.}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding CurrentInspection.StatusMessage}" TextWrapping="Wrap" />

                        <!-- Memory Editor -->
                        <TextBlock Text="MEMORY EDITOR" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#808080" Margin="0,14,0,6" />
                        <Border Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="1"
                                Padding="10" CornerRadius="3" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Address" Margin="0,0,10,6" VerticalAlignment="Center" FontSize="12" />
                                    <TextBox x:Name="AddressTextBox" Grid.Column="1" Text="0x0" FontSize="12" />
                                    <TextBlock Grid.Row="1" Text="Type" Margin="0,6,10,6" VerticalAlignment="Center" FontSize="12" />
                                    <ComboBox x:Name="TypeComboBox" Grid.Row="1" Grid.Column="1"
                                              Margin="0,4,0,0" Loaded="OnTypeComboBoxLoaded" FontSize="12" />
                                    <TextBlock Grid.Row="2" Text="Value" Margin="0,6,10,0" VerticalAlignment="Center" FontSize="12" />
                                    <TextBox x:Name="ValueTextBox" Grid.Row="2" Grid.Column="1"
                                             Text="0" Margin="0,4,0,0" FontSize="12" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Padding="8,3" Margin="0,0,6,0" Click="ReadAddress" Content="Read" FontSize="11" />
                                    <Button Padding="8,3" Margin="0,0,6,0" Click="WriteAddress" Content="Write" FontSize="11" />
                                    <Button Padding="8,3" Click="AddManualToTable" Content="Add to table" FontSize="11"
                                            Style="{StaticResource ToolbarButton}" />
                                </StackPanel>

                                <TextBlock Margin="0,10,0,2" FontWeight="SemiBold" Text="Last probe" FontSize="11" Foreground="#808080" />
                                <TextBlock Text="{Binding CurrentInspection.ManualProbe.Address, TargetNullValue=No manual probe yet}" FontSize="12" />
                                <TextBlock Text="{Binding CurrentInspection.ManualProbe.DataType, StringFormat=Type: {0}}" FontSize="12" />
                                <TextBlock Text="{Binding CurrentInspection.ManualProbe.DisplayValue, StringFormat=Value: {0}}" FontSize="12" />
                                <TextBlock FontFamily="Consolas" Text="{Binding CurrentInspection.ManualProbe.HexBytes}"
                                           TextWrapping="Wrap" FontSize="12" />
                                <TextBlock Margin="0,8,0,2" FontWeight="SemiBold" Text="Last write" FontSize="11" Foreground="#808080" />
                                <TextBlock Text="{Binding CurrentInspection.LastWriteMessage, TargetNullValue=No writes issued in this session.}"
                                           TextWrapping="Wrap" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Modules -->
                        <TextBlock Text="MODULES" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#808080" Margin="0,6,0,6" />
                        <ListView x:Name="ModulesList" ItemsSource="{Binding CurrentInspection.Modules}" MaxHeight="160"
                                  Background="#252526" BorderThickness="0" FontSize="12"
                                  PreviewMouseLeftButtonDown="ModuleList_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="ModuleList_PreviewMouseMove">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Foreground="#808080" Text="{Binding BaseAddress}" />
                                        <TextBlock Foreground="#808080" Text="{Binding Size}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Disassembly -->
                        <TextBlock Text="DISASSEMBLY" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#808080" Margin="0,10,0,6" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox x:Name="DisasmAddressTextBox" Width="180" Margin="0,0,6,0"
                                     Text="0x0" FontSize="12" />
                            <Button Padding="8,3" Click="DisassembleAtAddress" Content="Disassemble" FontSize="11" />
                        </StackPanel>
                        <TextBlock Margin="0,0,0,6" Foreground="#808080" FontSize="12"
                                   Text="{Binding Disassembly.Summary, TargetNullValue=Enter an address and click Disassemble.}" />
                        <ListView ItemsSource="{Binding Disassembly.Lines}" MaxHeight="240"
                                  FontFamily="Consolas" FontSize="11" Background="#1E1E1E">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Address" Width="130"
                                                    DisplayMemberBinding="{Binding Address}" />
                                    <GridViewColumn Header="Bytes" Width="140"
                                                    DisplayMemberBinding="{Binding HexBytes}" />
                                    <GridViewColumn Header="Instruction" Width="80"
                                                    DisplayMemberBinding="{Binding Mnemonic}" />
                                    <GridViewColumn Header="Operands" Width="200"
                                                    DisplayMemberBinding="{Binding Operands}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Breakpoints -->
                        <TextBlock Text="BREAKPOINTS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#808080" Margin="0,10,0,6" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox x:Name="BpAddressTextBox" Width="150" Margin="0,0,6,0"
                                     Text="0x0" FontSize="12" />
                            <ComboBox x:Name="BpTypeComboBox" Width="130" Margin="0,0,6,0"
                                      Loaded="OnBpTypeComboBoxLoaded" FontSize="12" />
                            <Button Padding="8,3" Click="SetBreakpoint" Content="Set BP" FontSize="11" />
                        </StackPanel>
                        <TextBlock Margin="0,0,0,4" Foreground="#808080" FontSize="12"
                                   Text="{Binding BreakpointStatus, TargetNullValue=No breakpoints set. Attach to a process first.}" />
                        <ListView x:Name="BreakpointListView" MaxHeight="150"
                                  FontFamily="Consolas" FontSize="11" Background="#1E1E1E">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="100"
                                                    DisplayMemberBinding="{Binding Id}" />
                                    <GridViewColumn Header="Address" Width="120"
                                                    DisplayMemberBinding="{Binding Address}" />
                                    <GridViewColumn Header="Type" Width="90"
                                                    DisplayMemberBinding="{Binding Type}" />
                                    <GridViewColumn Header="Hits" Width="50"
                                                    DisplayMemberBinding="{Binding HitCount}" />
                                    <GridViewColumn Header="Status" Width="70"
                                                    DisplayMemberBinding="{Binding Status}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Padding="8,3" Margin="0,0,6,0" Click="RemoveBreakpoint" Content="Remove"
                                    FontSize="11" Style="{StaticResource ToolbarButton}" />
                            <Button Padding="8,3" Margin="0,0,6,0" Click="RefreshBreakpoints" Content="Refresh"
                                    FontSize="11" Style="{StaticResource ToolbarButton}" />
                            <Button Padding="8,3" Click="ViewHitLog" Content="View hits"
                                    FontSize="11" Style="{StaticResource ToolbarButton}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Horizontal GridSplitter between center sections -->
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              VerticalAlignment="Center" ResizeDirection="Rows" />

                <!-- Center Bottom: Memory Scanner -->
                <DockPanel Grid.Row="2" Background="#252526">
                    <TextBlock DockPanel.Dock="Top" Text="MEMORY SCANNER" FontSize="11" FontWeight="SemiBold"
                               Foreground="#808080" Margin="8,8,8,4" />
                    <StackPanel DockPanel.Dock="Top" Margin="8,0,8,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Scan type" FontSize="11" Margin="0,0,0,3" />
                                <ComboBox x:Name="ScanTypeComboBox" Loaded="OnScanTypeComboBoxLoaded" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Data type" FontSize="11" Margin="0,0,0,3" />
                                <ComboBox x:Name="ScanDataTypeComboBox" Loaded="OnScanDataTypeComboBoxLoaded" FontSize="12" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Value" FontSize="11" Margin="0,6,0,3" />
                        <TextBox x:Name="ScanValueTextBox" Text="" FontSize="12" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Padding="8,3" Margin="0,0,6,0" Click="StartNewScan" Content="New scan" FontSize="11" />
                            <Button Padding="8,3" Margin="0,0,6,0" Click="RefineScan" Content="Next scan" FontSize="11" />
                            <Button Padding="8,3" Margin="0,0,6,0" Click="ResetScan" Content="Reset"
                                    FontSize="11" Style="{StaticResource ToolbarButton}" />
                            <Button Padding="8,3" Click="AddSelectedScanResultToTable" Content="Add to table"
                                    FontSize="11" Style="{StaticResource ToolbarButton}" />
                        </StackPanel>
                        <Border Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="3" Padding="8" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" FontSize="12"
                                           Text="{Binding ScanStatus, TargetNullValue=No scan active}" />
                                <TextBlock Margin="0,2,0,0" Foreground="#808080" FontSize="11"
                                           Text="{Binding ScanDetails}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <ListView x:Name="ScanResultsList" ItemsSource="{Binding ScanResults}"
                              Background="#1E1E1E" FontSize="11" BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Address" Width="130"
                                                DisplayMemberBinding="{Binding Address}" />
                                <GridViewColumn Header="Value" Width="100"
                                                DisplayMemberBinding="{Binding CurrentValue}" />
                                <GridViewColumn Header="Previous" Width="100"
                                                DisplayMemberBinding="{Binding PreviousValue}" />
                                <GridViewColumn Header="Hex" Width="100"
                                                DisplayMemberBinding="{Binding HexBytes}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Grid>

            <!-- Vertical GridSplitter -->
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" ResizeDirection="Columns" />

            <!-- RIGHT SIDEBAR: AI Operator -->
            <DockPanel Grid.Column="4" Background="#252526"
                       AllowDrop="True" Drop="AiPanel_Drop" DragOver="AiPanel_DragOver">
                <TextBlock DockPanel.Dock="Top" FontSize="11" FontWeight="SemiBold"
                           Foreground="#808080" Margin="8,8,8,4">
                    <Run Text="AI OPERATOR" /><Run Text="  (drag items here)" FontSize="9" Foreground="#555555" />
                </TextBlock>
                <!-- Chat switcher -->
                <Grid DockPanel.Dock="Top" Margin="8,0,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ChatSwitcher" Grid.Column="0" FontSize="11"
                              Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#3C3C3C"
                              SelectionChanged="ChatSwitcher_SelectionChanged"
                              DisplayMemberPath="Title" />
                    <Button Grid.Column="1" Content="+" Padding="6,2" Margin="4,0,0,0"
                            FontSize="11" ToolTip="New Chat" Click="NewAiChat"
                            Style="{StaticResource ToolbarButton}" />
                    <Button Grid.Column="2" Content="✕" Padding="6,2" Margin="4,0,0,0"
                            FontSize="11" ToolTip="Delete Chat" Click="DeleteAiChat"
                            Style="{StaticResource ToolbarButton}" />
                </Grid>
                <StackPanel DockPanel.Dock="Bottom" Margin="8,4,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AiChatInputTextBox" Grid.Column="0" Margin="0,0,6,0"
                                 Padding="8,6" FontSize="12" KeyDown="OnAiChatKeyDown"
                                 Background="#1E1E1E" BorderBrush="#3C3C3C" />
                        <Button Grid.Column="1" Padding="12,6" Click="SendAiMessage" Content="Send" FontSize="11" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Padding="6,2" Margin="0,0,6,0" Click="ClearAiChat" Content="Clear"
                                FontSize="10" Style="{StaticResource ToolbarButton}" />
                        <TextBlock x:Name="AiStatusText" VerticalAlignment="Center"
                                   Foreground="#808080" Text="Ready" FontSize="11" />
                    </StackPanel>
                </StackPanel>
                <ScrollViewer x:Name="AiChatScrollViewer" VerticalScrollBarVisibility="Auto" Margin="8,0,8,0">
                    <ItemsControl x:Name="AiChatList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="4"
                                        Background="{Binding Background}">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" FontSize="10"
                                                   Foreground="#808080" Text="{Binding RoleLabel}" />
                                        <TextBlock TextWrapping="Wrap" Text="{Binding Content}" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- Row 3: Horizontal GridSplitter -->
        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" ResizeDirection="Rows" />

        <!-- Row 4: Address Table -->
        <DockPanel Grid.Row="4" Background="#252526" Margin="0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6,8,4">
                <TextBlock Text="ADDRESS TABLE" FontSize="11" FontWeight="SemiBold"
                           Foreground="#808080" VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="RefreshAddressTable" Content="Refresh" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="RemoveSelectedAddress" Content="Remove" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="ToggleLockAddress" Content="Lock" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="CreateAddressGroup" Content="Group" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="ExportAddressTable" Content="Export" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="ImportAddressTable" Content="Import" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="GenerateTrainerScript" Content="Trainer" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="ViewSelectedScript" Content="View Script" />
                <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Click="ToggleSelectedScript" Content="Toggle Script" />
                <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#808080" FontSize="11"
                           Text="{Binding AddressTableStatus, TargetNullValue=No addresses saved}" />
            </StackPanel>
            <!-- Column headers -->
            <Grid DockPanel.Dock="Top" Margin="22,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="" FontWeight="Bold" Foreground="#808080" FontSize="11" />
                <TextBlock Grid.Column="1" Text="" FontWeight="Bold" Foreground="#808080" FontSize="11" />
                <TextBlock Grid.Column="2" Text="Description" FontWeight="Bold" Foreground="#808080" FontSize="11" />
                <TextBlock Grid.Column="3" Text="Address" FontWeight="Bold" Foreground="#808080" FontSize="11" />
                <TextBlock Grid.Column="4" Text="Type" FontWeight="Bold" Foreground="#808080" FontSize="11" />
                <TextBlock Grid.Column="5" Text="Value" FontWeight="Bold" Foreground="#808080" FontSize="11" />
            </Grid>
            <TreeView x:Name="AddressTableTree"
                      ItemsSource="{Binding AddressTableNodes}"
                      FontFamily="Consolas" FontSize="12"
                      Background="#1E1E1E" BorderThickness="0"
                      MouseDoubleClick="AddressTableTree_MouseDoubleClick"
                      KeyDown="AddressTableTree_KeyDown"
                      PreviewMouseLeftButtonDown="AddressTable_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="AddressTable_PreviewMouseMove">
                <TreeView.Resources>
                    <ContextMenu x:Key="NodeContextMenu" Background="#2D2D2D" Foreground="#CCCCCC" BorderBrush="#3C3C3C">
                        <MenuItem Header="Toggle Activate" Click="CtxToggleActivate" InputGestureText="Space" />
                        <Separator />
                        <MenuItem Header="Change Description" Click="CtxChangeDescription" />
                        <MenuItem Header="Change Address" Click="CtxChangeAddress" />
                        <MenuItem Header="Change Value" Click="CtxChangeValue" />
                        <MenuItem Header="Change Type" Click="CtxChangeType" />
                        <Separator />
                        <MenuItem Header="Toggle Freeze" Click="CtxToggleFreeze" InputGestureText="Ctrl+F" />
                        <MenuItem Header="Show as Hexadecimal" Click="CtxShowAsHex" IsCheckable="True" />
                        <Separator />
                        <MenuItem Header="View Script" Click="ViewSelectedScript" />
                        <MenuItem Header="Toggle Script" Click="ToggleSelectedScript" />
                        <Separator />
                        <MenuItem Header="Browse Memory Region" Click="CtxBrowseMemory" />
                        <MenuItem Header="Disassemble Here" Click="CtxDisassemble" />
                        <MenuItem Header="Find What Writes" Click="CtxFindWhatWrites" />
                        <MenuItem Header="View Write Log" Click="CtxViewWriteLog" />
                        <Separator />
                        <MenuItem Header="Create Group" Click="CreateAddressGroup" />
                        <MenuItem Header="Move to Group..." Click="CtxMoveToGroup" />
                        <MenuItem Header="Delete" Click="CtxDelete" InputGestureText="Del" />
                        <Separator />
                        <MenuItem Header="Cut" Click="CtxCut" InputGestureText="Ctrl+X" />
                        <MenuItem Header="Copy" Click="CtxCopy" InputGestureText="Ctrl+C" />
                        <MenuItem Header="Paste" Click="CtxPaste" InputGestureText="Ctrl+V" />
                    </ContextMenu>
                </TreeView.Resources>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="ContextMenu" Value="{StaticResource NodeContextMenu}" />
                        <Setter Property="Foreground" Value="#CCCCCC" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Grid Margin="2" ToolTip="{Binding StatusTooltip}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                                      Click="ActiveCheckBox_Click"
                                      VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding DisplayIcon}" />
                            <TextBlock Grid.Column="2" Text="{Binding Label}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="{Binding DisplayAddress}" Foreground="#569CD6" />
                            <TextBlock Grid.Column="4" Text="{Binding DisplayType}" Foreground="#808080" />
                            <TextBlock Grid.Column="5"
                                       Text="{Binding DisplayValue}"
                                       Foreground="{Binding DisplayValueColor, Converter={StaticResource BrushConv}}"
                                       FontWeight="{Binding DisplayValueWeight}" />
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>
    </Grid>
</Window>
