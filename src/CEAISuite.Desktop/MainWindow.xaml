<Window x:Class="CEAISuite.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CEAISuite.Desktop"
        xmlns:models="clr-namespace:CEAISuite.Desktop.Models"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="CE AI Suite"
        Height="860"
        Width="1500"
        MinHeight="700"
        MinWidth="1100"
        Background="{DynamicResource WindowBackground}">
    <Window.Resources>
        <local:StringToBrushConverter x:Key="BrushConv" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <!-- NOTE: All default control styles are now in Themes/SharedStyles.xaml (merged at App level).
             SystemColors are updated at runtime in UpdateSystemSelectionColors(). -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Command Bar -->
        <Border Grid.Row="0" Background="{DynamicResource MenuBarBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Right side: Emergency Stop + Hamburger menu + Settings gear -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Content="⚠ Stop" Padding="8,3" FontSize="11"
                            Click="CmdEmergencyStop" Foreground="OrangeRed" FontWeight="SemiBold"
                            Style="{StaticResource ToolbarButton}"
                            ToolTip="Emergency: rollback all patches + force detach (Ctrl+Shift+Esc)" />
                    <Menu Background="Transparent" VerticalAlignment="Center">
                        <MenuItem Header="⋯" FontSize="14" FontWeight="Bold" ToolTip="Menu (Alt)"
                                  Padding="8,4">
                            <MenuItem Header="_Windows">
                                <MenuItem Header="_Processes" Click="ShowPanel" Tag="processes" />
                                <MenuItem Header="_Modules" Click="ShowPanel" Tag="modules" />
                                <MenuItem Header="_Threads" Click="ShowPanel" Tag="threads" />
                                <MenuItem Header="Memory _Map" Click="ShowPanel" Tag="memoryRegions" />
                                <MenuItem Header="_Workspace" Click="ShowPanel" Tag="workspace" />
                                <Separator />
                                <MenuItem Header="_Scanner" Click="ShowPanel" Tag="scanner" />
                                <MenuItem Header="_Output" Click="ShowPanel" Tag="output" />
                                <MenuItem Header="_AI Operator" Click="ShowPanel" Tag="aiOperator" />
                                <Separator />
                                <MenuItem Header="_Address Table" Click="ShowPanel" Tag="addressTable" />
                                <MenuItem Header="_Inspection" Click="ShowPanel" Tag="inspection" />
                                <MenuItem Header="Memory _Browser" Click="ShowPanel" Tag="memoryBrowser" />
                                <MenuItem Header="_Disassembler" Click="ShowPanel" Tag="disassembler" />
                                <MenuItem Header="S_tructure Dissector" Click="ShowPanel" Tag="structureDissector" />
                                <MenuItem Header="_Pointer Scanner" Click="ShowPanel" Tag="pointerScanner" />
                                <MenuItem Header="Script _Editor" Click="ShowPanel" Tag="scriptEditor" />
                                <MenuItem Header="De_bugger" Click="ShowPanel" Tag="debugger" />
                                <MenuItem Header="_Lua Console" Click="ShowPanel" Tag="luaConsole" />
                                <Separator />
                                <MenuItem Header="_Breakpoints" Click="ShowPanel" Tag="breakpoints" />
                                <MenuItem Header="S_cripts" Click="ShowPanel" Tag="scripts" />
                                <MenuItem Header="S_napshots" Click="ShowPanel" Tag="snapshots" />
                                <MenuItem Header="_Find Results" Click="ShowPanel" Tag="findResults" />
                                <MenuItem Header="_Hotkeys" Click="ShowPanel" Tag="hotkeys" />
                                <MenuItem Header="_Journal" Click="ShowPanel" Tag="journal" />
                            </MenuItem>
                            <MenuItem Header="S_kills">
                                <MenuItem Header="_Manage Skills…" Click="OpenSkillsManager" />
                                <MenuItem Header="Open Skills _Folder" Click="OpenSkillsFolder" />
                                <Separator />
                                <MenuItem Header="_Reload Skills" Click="ReloadSkills" />
                            </MenuItem>
                            <MenuItem Header="_Tools">
                                <MenuItem Header="Capture _Screenshot" Click="CaptureScreenshot"
                                          ToolTip="Capture the target process window (same as AI tool)" />
                                <MenuItem Header="Export _Report…" Click="ExportReport"
                                          ToolTip="Generate an investigation summary report" />
                            </MenuItem>
                            <MenuItem Header="MCP _Servers">
                                <MenuItem Header="_Manage Servers…" Click="OpenMcpManager" />
                            </MenuItem>
                            <MenuItem Header="_Help">
                                <MenuItem Header="_About CE AI Suite" Click="ShowAbout" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="E_xit" Click="ExitApp" />
                        </MenuItem>
                    </Menu>
                    <Button Content="⚙" FontSize="14" Padding="8,4" ToolTip="Settings"
                            Click="OpenSettings" Style="{StaticResource ToolbarButton}" />
                </StackPanel>

                <!-- Left side: Command buttons -->
                <ToolBarTray DockPanel.Dock="Left" Background="Transparent" IsLocked="True">
                    <ToolBar Background="Transparent" Band="0" BandIndex="0"
                             OverflowMode="Never">
                        <ToolBar.Resources>
                            <!-- Override ToolBar's default chrome so children respect our theme -->
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ToolbarButtonBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource ToolbarButtonForeground}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="8,3" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ToolbarButtonHoverBackground}" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ToolbarButtonPressedBackground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="{DynamicResource InputBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
                                <Setter Property="CaretBrush" Value="{DynamicResource InputCaret}" />
                                <Setter Property="BorderThickness" Value="1" />
                            </Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Setter Property="Background" Value="{DynamicResource InputBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
                                <Setter Property="BorderThickness" Value="1" />
                            </Style>
                            <Style TargetType="Separator">
                                <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                                <Setter Property="Margin" Value="4,2" />
                            </Style>
                        </ToolBar.Resources>
                        <!-- Session I/O -->
                        <Button Content="📂 Load" Padding="8,3" FontSize="11" Click="LoadSession"
                                ToolTip="Load session" />
                        <Button Content="💾 Save" Padding="8,3" FontSize="11" Click="SaveSession"
                                ToolTip="Save session (Ctrl+S)" />
                        <Button Content="📥 Load CT" Padding="8,3" FontSize="11" Click="OnLoadCheatTable"
                                ToolTip="Load Cheat Table (.CT)" />
                        <Button Content="📤 Export CT" Padding="8,3" FontSize="11" Click="OnSaveCheatTable"
                                ToolTip="Export Cheat Table (.CT)" />
                        <Separator />

                        <!-- Process controls -->
                        <ComboBox x:Name="ProcessComboBox" Width="180" FontSize="11"
                                  ToolTip="Select process (Ctrl+P)"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  DisplayMemberPath="Label"
                                  MaxDropDownHeight="300"
                                  DropDownOpened="ProcessComboBox_DropDownOpened" />
                        <Button Content="📎 Attach" Padding="8,3" FontSize="11" Click="CmdAttachProcess"
                                ToolTip="Attach to selected process" />
                        <Button Content="⏏ Detach" Padding="8,3" FontSize="11" Click="CmdDetachProcess"
                                ToolTip="Detach from process" />
                        <Separator />

                        <!-- Quick scan (bound to ScannerViewModel via ScannerContent) -->
                        <TextBox x:Name="ToolbarScanValue" Width="120" FontSize="11" VerticalContentAlignment="Center"
                                 ToolTip="Scan value"
                                 Text="{Binding DataContext.ScanValue, ElementName=ScannerContent, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox x:Name="ToolbarScanType" Width="70" FontSize="11"
                                  ToolTip="Data type" Loaded="OnToolbarScanTypeLoaded"
                                  SelectedItem="{Binding DataContext.SelectedDataType, ElementName=ScannerContent, Mode=TwoWay}" />
                        <Button Content="🔍 Scan" Padding="8,3" FontSize="11"
                                Command="{Binding DataContext.StartNewScanCommand, ElementName=ScannerContent}"
                                ToolTip="New scan (uses value and type above)" />
                        <Button Content="🔎 Next" Padding="8,3" FontSize="11"
                                Command="{Binding DataContext.RefineScanCommand, ElementName=ScannerContent}"
                                ToolTip="Refine/next scan" />
                        <Separator />

                        <!-- Undo / Redo -->
                        <Button Content="↩ Undo" Padding="8,3" FontSize="11" Click="MenuUndo"
                                ToolTip="Undo last patch (Ctrl+Z)" />
                        <Button Content="↪ Redo" Padding="8,3" FontSize="11" Click="MenuRedo"
                                ToolTip="Redo (Ctrl+Y)" />
                        <Separator />

                        <!-- Script -->
                        <Button Content="▶ Run/Stop" Padding="8,3" FontSize="11" Click="CmdRunScript"
                                ToolTip="Toggle selected script (F5)" />
                    </ToolBar>
                </ToolBarTray>
            </DockPanel>
        </Border>

        <!-- Row 1: Dockable Panel Layout -->
        <avalonDock:DockingManager x:Name="DockManager" Grid.Row="1">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">

                    <!-- Left sidebar: Process List -->
                    <avalonDock:LayoutAnchorablePane DockWidth="450" DockMinWidth="300">
                        <avalonDock:LayoutAnchorable Title="Processes" ContentId="processes">
                            <DockPanel x:Name="ProcessesContent" Background="{DynamicResource SidebarBackground}">
                                <TextBlock DockPanel.Dock="Top" Text="PROCESSES" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,8,8,4" />
                                <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}"
                                           TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="8,0,8,4" />
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,6">
                                    <Button Padding="8,3" Margin="0,0,6,0" Click="InspectSelectedProcess"
                                            Content="Inspect" FontSize="11" />
                                    <Button Padding="8,3" Command="{Binding RefreshCommand}" Content="Refresh"
                                            FontSize="11" Style="{StaticResource ToolbarButton}" />
                                </StackPanel>
                                <TextBox DockPanel.Dock="Top" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="8,0,8,6" Padding="4,3" FontSize="11"
                                         Background="{DynamicResource InputBackground}"
                                         Foreground="{DynamicResource PrimaryForeground}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         ToolTip="Filter by process name or PID" />
                                <ListView x:Name="RunningProcessesList" ItemsSource="{Binding Processes}"
                                          SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                                          Background="{DynamicResource SidebarBackground}" BorderThickness="0"
                                          PreviewMouseLeftButtonDown="ProcessList_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="ProcessList_PreviewMouseMove">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" FontSize="12" />
                                                    <TextBlock Text="{Binding Id, StringFormat=PID {0}}" Foreground="{DynamicResource SecondaryForeground}" FontSize="11" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Padding="4,1" Background="{DynamicResource InputBackground}" CornerRadius="3">
                                                    <TextBlock FontSize="10" Text="{Binding Architecture}" Foreground="{DynamicResource SecondaryForeground}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock DockPanel.Dock="Bottom" Text="{Binding ProcessDetails}"
                                           Foreground="{DynamicResource AccentForeground}" FontSize="11" FontWeight="SemiBold" Margin="8,4"
                                           Visibility="{Binding IsAttached, Converter={StaticResource BoolToVisibility}}" />
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>

                        <!-- Phase 4: Modules -->
                        <avalonDock:LayoutAnchorable Title="Modules" ContentId="modules">
                            <DockPanel x:Name="ModulesContent" Background="{DynamicResource SidebarBackground}">
                                <TextBlock DockPanel.Dock="Top" Text="MODULES" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,8,8,4" />
                                <TextBox DockPanel.Dock="Top" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="8,0,8,4" FontSize="11" FontFamily="Consolas"
                                         Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                         BorderBrush="{DynamicResource InputBorder}" CaretBrush="{DynamicResource InputCaret}" Padding="4,2" />
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,6">
                                    <Button Command="{Binding RefreshCommand}" Content="Refresh" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" />
                                    <Button Command="{Binding CopyAddressCommand}" Content="Copy Addr" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                    <Button Command="{Binding NavigateToDisassemblyCommand}" Content="Disasm" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,4" />
                                <ListView ItemsSource="{Binding Modules}" SelectedItem="{Binding SelectedModule, Mode=TwoWay}"
                                          Background="{DynamicResource SidebarBackground}" BorderThickness="0" FontSize="12">
                                    <ListView.ContextMenu>
                                        <ContextMenu Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                            <MenuItem Header="Copy Address" Command="{Binding CopyAddressCommand}" />
                                            <Separator />
                                            <MenuItem Header="Browse Memory" Command="{Binding BrowseMemoryCommand}" />
                                            <MenuItem Header="Disassemble" Command="{Binding NavigateToDisassemblyCommand}" />
                                            <MenuItem Header="Dissect Structure" Command="{Binding DissectModuleCommand}" />
                                            <Separator />
                                            <MenuItem Header="Ask AI About This" Command="{Binding AskAiCommand}" />
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" FontSize="12" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding BaseAddress}" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource SecondaryForeground}" />
                                                    <TextBlock Text=" | " FontSize="10" Foreground="{DynamicResource SecondaryForeground}" />
                                                    <TextBlock Text="{Binding Size}" FontSize="10" Foreground="{DynamicResource SecondaryForeground}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>

                        <!-- Phase 4: Threads -->
                        <avalonDock:LayoutAnchorable Title="Threads" ContentId="threads">
                            <DockPanel x:Name="ThreadsContent" Background="{DynamicResource SidebarBackground}">
                                <TextBlock DockPanel.Dock="Top" Text="THREADS" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,8,8,4" />
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,6">
                                    <Button Command="{Binding RefreshCommand}" Content="Refresh" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" />
                                    <Button Command="{Binding ExpandStackCommand}" Content="Expand Stack" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                    <Button Command="{Binding NavigateToInstructionCommand}" Content="Go To" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,4" />
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MaxHeight="180" />
                                    </Grid.RowDefinitions>
                                    <ListView Grid.Row="0" ItemsSource="{Binding Threads}" SelectedItem="{Binding SelectedThread, Mode=TwoWay}"
                                              Background="{DynamicResource SidebarBackground}" BorderThickness="0" FontSize="12">
                                        <ListView.ContextMenu>
                                            <ContextMenu Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                                <MenuItem Header="Copy Thread ID" Command="{Binding CopyThreadIdCommand}" />
                                                <MenuItem Header="Copy Instruction Pointer" Command="{Binding CopyInstructionPointerCommand}" />
                                                <Separator />
                                                <MenuItem Header="Disassemble at RIP" Command="{Binding NavigateToInstructionCommand}" />
                                                <MenuItem Header="Browse Stack" Command="{Binding BrowseStackCommand}" />
                                                <MenuItem Header="Expand Stack" Command="{Binding ExpandStackCommand}" />
                                                <Separator />
                                                <MenuItem Header="Ask AI About This" Command="{Binding AskAiCommand}" />
                                            </ContextMenu>
                                        </ListView.ContextMenu>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding ThreadId, StringFormat=Thread {0}}" FontSize="12" />
                                                        <TextBlock Text="{Binding State, StringFormat= ({0})}" FontSize="11" Foreground="{DynamicResource SecondaryForeground}" Margin="4,0,0,0" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CurrentInstruction}" FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource SecondaryForeground}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}" />
                                    <ListView Grid.Row="2" ItemsSource="{Binding ExpandedStack}" FontFamily="Consolas" FontSize="10"
                                              Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="#" Width="25" DisplayMemberBinding="{Binding FrameIndex}" />
                                                <GridViewColumn Header="Module+Offset" Width="180" DisplayMemberBinding="{Binding ModuleOffset}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>

                        <!-- Phase 4: Memory Map -->
                        <avalonDock:LayoutAnchorable Title="Memory Map" ContentId="memoryRegions">
                            <DockPanel x:Name="MemoryRegionsContent" Background="{DynamicResource SidebarBackground}">
                                <TextBlock DockPanel.Dock="Top" Text="MEMORY MAP" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,8,8,4" />
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,6">
                                    <Button Command="{Binding RefreshCommand}" Content="Refresh" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" />
                                    <TextBlock Text="Filter:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0" />
                                    <ComboBox ItemsSource="{Binding ProtectionFilters}" SelectedItem="{Binding FilterProtection}" Width="60" FontSize="11"
                                              Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" />
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,4" />
                                <ListView ItemsSource="{Binding Regions}" SelectedItem="{Binding SelectedRegion, Mode=TwoWay}"
                                          Background="{DynamicResource SidebarBackground}" BorderThickness="0" FontSize="11" FontFamily="Consolas">
                                    <ListView.ContextMenu>
                                        <ContextMenu Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                            <MenuItem Header="Copy Address" Command="{Binding CopyAddressCommand}" />
                                            <MenuItem Header="Copy Region Info" Command="{Binding CopyRegionInfoCommand}" />
                                            <Separator />
                                            <MenuItem Header="Browse Memory" Command="{Binding NavigateToMemoryBrowserCommand}" />
                                            <MenuItem Header="Disassemble" Command="{Binding DisassembleRegionCommand}" />
                                            <Separator />
                                            <MenuItem Header="Ask AI About This" Command="{Binding AskAiCommand}" />
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Address" Width="110" DisplayMemberBinding="{Binding BaseAddress}" />
                                            <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding Size}" />
                                            <GridViewColumn Header="Prot" Width="40" DisplayMemberBinding="{Binding Protection}" />
                                            <GridViewColumn Header="Module" Width="80" DisplayMemberBinding="{Binding OwnerModule}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>

                        <!-- Phase 4: Workspace -->
                        <avalonDock:LayoutAnchorable Title="Workspace" ContentId="workspace">
                            <DockPanel x:Name="WorkspaceContent" Background="{DynamicResource SidebarBackground}">
                                <TextBlock DockPanel.Dock="Top" Text="WORKSPACE" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,8,8,4" />
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,6">
                                    <Button Command="{Binding RefreshCommand}" Content="Refresh" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" />
                                    <Button Command="{Binding LoadSelectedCommand}" Content="Load" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                    <Button Command="{Binding DeleteSelectedCommand}" Content="Delete" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                    <Button Command="{Binding ImportCheatTableCommand}" Content="Import CT" FontSize="11" Padding="8,3" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="8,4" />
                                <ListView ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                                          Background="{DynamicResource SidebarBackground}" BorderThickness="0" FontSize="12">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding ProcessName}" FontSize="12" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding CreatedAt}" FontSize="10" Foreground="{DynamicResource SecondaryForeground}" />
                                                    <TextBlock Text="{Binding AddressCount, StringFormat= | {0} entries}" FontSize="10" Foreground="{DynamicResource SecondaryForeground}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <!-- Center panels -->
                    <avalonDock:LayoutPanel Orientation="Vertical" DockWidth="*">
                        <avalonDock:LayoutDocumentPane DockHeight="*">
                            <avalonDock:LayoutDocument Title="Address Table" ContentId="addressTable">
                                <DockPanel x:Name="AddressTableContent" Background="{DynamicResource SidebarBackground}" Grid.IsSharedSizeScope="True">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6,8,4">
                                        <TextBlock Text="ADDRESS TABLE" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RefreshCommand}" Content="Refresh" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RemoveSelectedCommand}" Content="Remove" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding ToggleLockCommand}" Content="Lock" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding CreateGroupCommand}" Content="Group" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding ExportCommand}" Content="Export" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding ImportCommand}" Content="Import" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding GenerateTrainerCommand}" Content="Trainer" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding ViewSelectedScriptCommand}" Content="View Script" />
                                        <Button Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding ToggleSelectedScriptCommand}" Content="Toggle Script" />
                                        <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource SecondaryForeground}" FontSize="11"
                                                   Text="{Binding AddressTableStatus, TargetNullValue=No addresses saved}" />
                                    </StackPanel>
                                    <!-- Column headers (clickable for sorting, drag-resizable via GridSplitters) -->
                                    <Grid DockPanel.Dock="Top" Margin="22,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" SharedSizeGroup="ATChk" />
                                            <ColumnDefinition Width="24" SharedSizeGroup="ATIcon" />
                                            <ColumnDefinition Width="200" MinWidth="60" SharedSizeGroup="ATDesc" />
                                            <ColumnDefinition Width="Auto" /><!-- splitter -->
                                            <ColumnDefinition Width="160" MinWidth="60" SharedSizeGroup="ATAddr" />
                                            <ColumnDefinition Width="Auto" /><!-- splitter -->
                                            <ColumnDefinition Width="100" MinWidth="40" SharedSizeGroup="ATType" />
                                            <ColumnDefinition Width="Auto" /><!-- splitter -->
                                            <ColumnDefinition Width="*" MinWidth="60" SharedSizeGroup="ATVal" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="" FontSize="11" />
                                        <TextBlock Grid.Column="1" Text="" FontSize="11" />
                                        <TextBlock Grid.Column="2" Text="Description" FontWeight="Bold" Foreground="{DynamicResource SecondaryForeground}" FontSize="11"
                                                   Cursor="Hand" MouseLeftButtonUp="SortAddressTable" Tag="Label"
                                                   ToolTip="Click to sort by description" />
                                        <GridSplitter Grid.Column="3" Width="3" Background="{DynamicResource BorderBrush}" Cursor="SizeWE"
                                                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />
                                        <TextBlock Grid.Column="4" Text="Address" FontWeight="Bold" Foreground="{DynamicResource SecondaryForeground}" FontSize="11"
                                                   Cursor="Hand" MouseLeftButtonUp="SortAddressTable" Tag="Address"
                                                   ToolTip="Click to sort by address" />
                                        <GridSplitter Grid.Column="5" Width="3" Background="{DynamicResource BorderBrush}" Cursor="SizeWE"
                                                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />
                                        <TextBlock Grid.Column="6" Text="Type" FontWeight="Bold" Foreground="{DynamicResource SecondaryForeground}" FontSize="11"
                                                   Cursor="Hand" MouseLeftButtonUp="SortAddressTable" Tag="Type"
                                                   ToolTip="Click to sort by data type" />
                                        <GridSplitter Grid.Column="7" Width="3" Background="{DynamicResource BorderBrush}" Cursor="SizeWE"
                                                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />
                                        <TextBlock Grid.Column="8" Text="Value" FontWeight="Bold" Foreground="{DynamicResource SecondaryForeground}" FontSize="11"
                                                   Cursor="Hand" MouseLeftButtonUp="SortAddressTable" Tag="Value"
                                                   ToolTip="Click to sort by value" />
                                    </Grid>
                                    <TreeView x:Name="AddressTableTree"
                                              ItemsSource="{Binding Roots}"
                                              FontFamily="Consolas" FontSize="12"
                                              Background="{DynamicResource PanelBackground}" BorderThickness="0"
                                              AllowDrop="True" DragOver="AddressPanel_DragOver" Drop="AddressTable_Drop"
                                              MouseDoubleClick="AddressTableTree_MouseDoubleClick"
                                              KeyDown="AddressTableTree_KeyDown"
                                              PreviewMouseLeftButtonDown="AddressTable_PreviewMouseLeftButtonDown"
                                              PreviewMouseMove="AddressTable_PreviewMouseMove">
                                        <TreeView.Resources>
                                            <ContextMenu x:Key="NodeContextMenu" Background="{DynamicResource MenuBarBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderBrush="{DynamicResource BorderBrush}"
                                                         DataContext="{Binding DataContext, ElementName=AddressTableContent}">
                                                <MenuItem Header="Toggle Activate" Command="{Binding ToggleActivateCommand}" InputGestureText="Space" />
                                                <Separator />
                                                <MenuItem Header="Change Description" Command="{Binding ChangeDescriptionCommand}" />
                                                <MenuItem Header="Change Address" Command="{Binding ChangeAddressCommand}" />
                                                <MenuItem Header="Change Value" Command="{Binding ChangeValueCommand}" />
                                                <MenuItem Header="Change Type" Command="{Binding ChangeTypeCommand}" />
                                                <Separator />
                                                <MenuItem Header="Toggle Freeze" Command="{Binding ToggleFreezeCommand}" InputGestureText="Ctrl+F" />
                                                <MenuItem Header="Show as Hexadecimal" Command="{Binding ToggleShowAsHexCommand}" IsCheckable="True" />
                                                <MenuItem Header="Show as Signed" Command="{Binding ToggleShowAsSignedCommand}" IsCheckable="True" />
                                                <MenuItem Header="Increase Value" Command="{Binding IncreaseValueCommand}" InputGestureText="Ctrl+Up" />
                                                <MenuItem Header="Decrease Value" Command="{Binding DecreaseValueCommand}" InputGestureText="Ctrl+Down" />
                                                <MenuItem Header="Configure Dropdown..." Command="{Binding ConfigureDropDownCommand}" />
                                                <Separator />
                                                <MenuItem Header="View Script" Command="{Binding ViewSelectedScriptCommand}" />
                                                <MenuItem Header="Toggle Script" Command="{Binding ToggleSelectedScriptCommand}" />
                                                <Separator />
                                                <MenuItem Header="Browse Memory Region" Command="{Binding BrowseMemoryCommand}" />
                                                <MenuItem Header="Disassemble Here" Command="{Binding DisassembleCommand}" />
                                                <MenuItem Header="Find What Writes" Command="{Binding FindWhatWritesCommand}" />
                                                <MenuItem Header="View Write Log" Command="{Binding ViewWriteLogCommand}" />
                                                <Separator />
                                                <MenuItem Header="Create Group" Command="{Binding CreateGroupCommand}" />
                                                <MenuItem Header="Move to Group..." Command="{Binding MoveToGroupCommand}" />
                                                <MenuItem Header="Delete" Command="{Binding DeleteCommand}" InputGestureText="Del" />
                                                <Separator />
                                                <MenuItem Header="Cut" Command="{Binding CutCommand}" InputGestureText="Ctrl+X" />
                                                <MenuItem Header="Copy" Command="{Binding CopyCommand}" InputGestureText="Ctrl+C" />
                                                <MenuItem Header="Paste" Command="{Binding PasteCommand}" InputGestureText="Ctrl+V" />
                                                <Separator />
                                                <MenuItem Header="Set Color">
                                                    <MenuItem Header="None" Command="{Binding SetColorCommand}" CommandParameter="" />
                                                    <MenuItem Header="Red" Command="{Binding SetColorCommand}" CommandParameter="#FF4444" />
                                                    <MenuItem Header="Green" Command="{Binding SetColorCommand}" CommandParameter="#44AA44" />
                                                    <MenuItem Header="Blue" Command="{Binding SetColorCommand}" CommandParameter="#4488FF" />
                                                    <MenuItem Header="Yellow" Command="{Binding SetColorCommand}" CommandParameter="#DDAA00" />
                                                    <MenuItem Header="Purple" Command="{Binding SetColorCommand}" CommandParameter="#AA44CC" />
                                                    <MenuItem Header="Orange" Command="{Binding SetColorCommand}" CommandParameter="#FF8800" />
                                                    <MenuItem Header="Cyan" Command="{Binding SetColorCommand}" CommandParameter="#00AACC" />
                                                </MenuItem>
                                            </ContextMenu>
                                        </TreeView.Resources>
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                                <Setter Property="ContextMenu" Value="{StaticResource NodeContextMenu}" />
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <Grid Margin="2" ToolTip="{Binding StatusTooltip}"
                                                      Background="{Binding RowBackground, Converter={StaticResource BrushConv}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition SharedSizeGroup="ATChk" />
                                                        <ColumnDefinition SharedSizeGroup="ATIcon" />
                                                        <ColumnDefinition SharedSizeGroup="ATDesc" />
                                                        <ColumnDefinition Width="3" /><!-- splitter gap -->
                                                        <ColumnDefinition SharedSizeGroup="ATAddr" />
                                                        <ColumnDefinition Width="3" /><!-- splitter gap -->
                                                        <ColumnDefinition SharedSizeGroup="ATType" />
                                                        <ColumnDefinition Width="3" /><!-- splitter gap -->
                                                        <ColumnDefinition SharedSizeGroup="ATVal" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                              Click="ActiveCheckBox_Click"
                                                              VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayIcon}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Label}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="4" Text="{Binding DisplayAddress}" Foreground="{DynamicResource AccentForeground}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="6" Text="{Binding DisplayType}" Foreground="{DynamicResource SecondaryForeground}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="8"
                                                               Text="{Binding DisplayValue}"
                                                               Foreground="{Binding ValueForeground, Converter={StaticResource BrushConv}}"
                                                               FontWeight="{Binding DisplayValueWeight}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </DockPanel>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument Title="Inspection" ContentId="inspection">
                                <ScrollViewer x:Name="InspectionContent" VerticalScrollBarVisibility="Auto" Background="{DynamicResource SidebarBackground}">
                                    <StackPanel Margin="8">
                                        <!-- Process Inspection -->
                                        <TextBlock Text="PROCESS INSPECTION" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />
                                        <TextBlock FontSize="15" FontWeight="SemiBold"
                                                   Text="{Binding CurrentInspection.ProcessName, TargetNullValue=No process selected}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryForeground}"
                                                   Text="{Binding CurrentInspection.Architecture, TargetNullValue=Pick a running process to inspect modules and memory.}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding CurrentInspection.StatusMessage}" TextWrapping="Wrap" />

                                        <!-- Memory Editor -->
                                        <TextBlock Text="MEMORY EDITOR" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,14,0,6" />
                                        <Border Background="{DynamicResource MenuBarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                Padding="10" CornerRadius="3" Margin="0,0,0,8">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="Address" Margin="0,0,10,6" VerticalAlignment="Center" FontSize="12" />
                                                    <TextBox x:Name="AddressTextBox" Grid.Column="1" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" FontSize="12" />
                                                    <TextBlock Grid.Row="1" Text="Type" Margin="0,6,10,6" VerticalAlignment="Center" FontSize="12" />
                                                    <ComboBox x:Name="TypeComboBox" Grid.Row="1" Grid.Column="1"
                                                              Margin="0,4,0,0" Loaded="OnTypeComboBoxLoaded"
                                                              SelectedItem="{Binding SelectedDataType, Mode=TwoWay}" FontSize="12" />
                                                    <TextBlock Grid.Row="2" Text="Value" Margin="0,6,10,0" VerticalAlignment="Center" FontSize="12" />
                                                    <TextBox x:Name="ValueTextBox" Grid.Row="2" Grid.Column="1"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" FontSize="12" />
                                                </Grid>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Button Padding="8,3" Margin="0,0,6,0" Command="{Binding ReadAddressCommand}" Content="Read" FontSize="11" />
                                                    <Button Padding="8,3" Margin="0,0,6,0" Command="{Binding WriteAddressCommand}" Content="Write" FontSize="11" />
                                                    <Button Padding="8,3" Command="{Binding AddManualToTableCommand}" Content="Add to table" FontSize="11"
                                                            Style="{StaticResource ToolbarButton}" />
                                                </StackPanel>

                                                <TextBlock Margin="0,10,0,2" FontWeight="SemiBold" Text="Last probe" FontSize="11" Foreground="{DynamicResource SecondaryForeground}" />
                                                <TextBlock Text="{Binding CurrentInspection.ManualProbe.Address, TargetNullValue=No manual probe yet}" FontSize="12" />
                                                <TextBlock Text="{Binding CurrentInspection.ManualProbe.DataType, StringFormat=Type: {0}}" FontSize="12" />
                                                <TextBlock Text="{Binding CurrentInspection.ManualProbe.DisplayValue, StringFormat=Value: {0}}" FontSize="12" />
                                                <TextBlock FontFamily="Consolas" Text="{Binding CurrentInspection.ManualProbe.HexBytes}"
                                                           TextWrapping="Wrap" FontSize="12" />
                                                <TextBlock Margin="0,8,0,2" FontWeight="SemiBold" Text="Last write" FontSize="11" Foreground="{DynamicResource SecondaryForeground}" />
                                                <TextBlock Text="{Binding CurrentInspection.LastWriteMessage, TargetNullValue=No writes issued in this session.}"
                                                           TextWrapping="Wrap" FontSize="12" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Modules -->
                                        <TextBlock Text="MODULES" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,6,0,6" />
                                        <ListView x:Name="ModulesList" ItemsSource="{Binding CurrentInspection.Modules}" MaxHeight="160"
                                                  Background="{DynamicResource SidebarBackground}" BorderThickness="0" FontSize="12"
                                                  PreviewMouseLeftButtonDown="ModuleList_PreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="ModuleList_PreviewMouseMove">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,6">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                        <TextBlock Foreground="{DynamicResource SecondaryForeground}" Text="{Binding BaseAddress}" />
                                                        <TextBlock Foreground="{DynamicResource SecondaryForeground}" Text="{Binding Size}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <!-- Disassembly -->
                                        <TextBlock Text="DISASSEMBLY" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,10,0,6" />
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBox x:Name="DisasmAddressTextBox" Width="180" Margin="0,0,6,0"
                                                     Text="{Binding DisassemblyAddress, UpdateSourceTrigger=PropertyChanged}" FontSize="12" />
                                            <Button Padding="8,3" Command="{Binding DisassembleAtAddressCommand}" Content="Disassemble" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Margin="0,0,0,6" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"
                                                   Text="{Binding Disassembly.Summary, TargetNullValue=Enter an address and click Disassemble.}" />
                                        <ListView ItemsSource="{Binding Disassembly.Lines}" MaxHeight="240"
                                                  FontFamily="Consolas" FontSize="11" Background="{DynamicResource PanelBackground}">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Address" Width="130"
                                                                    DisplayMemberBinding="{Binding Address}" />
                                                    <GridViewColumn Header="Bytes" Width="140"
                                                                    DisplayMemberBinding="{Binding HexBytes}" />
                                                    <GridViewColumn Header="Instruction" Width="80"
                                                                    DisplayMemberBinding="{Binding Mnemonic}" />
                                                    <GridViewColumn Header="Operands" Width="200"
                                                                    DisplayMemberBinding="{Binding Operands}" />
                                                </GridView>
                                            </ListView.View>
                                        </ListView>

                                        <!-- Breakpoints -->
                                        <TextBlock Text="BREAKPOINTS" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,10,0,6" />
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBox x:Name="BpAddressTextBox" Width="150" Margin="0,0,6,0"
                                                     Text="{Binding BpAddress, UpdateSourceTrigger=PropertyChanged}" FontSize="12" />
                                            <ComboBox x:Name="BpTypeComboBox" Width="130" Margin="0,0,6,0"
                                                      Loaded="OnBpTypeComboBoxLoaded"
                                                      SelectedItem="{Binding SelectedBpType, Mode=TwoWay}" FontSize="12" />
                                            <Button Padding="8,3" Command="{Binding SetBreakpointCommand}" Content="Set BP" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"
                                                   Text="{Binding BreakpointStatus, TargetNullValue=No breakpoints set. Use the Breakpoints tab to manage.}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument Title="Memory Browser" ContentId="memoryBrowser">
                                <local:MemoryBrowserControl x:Name="MemoryBrowserTab"
                                    AllowDrop="True" DragOver="AddressPanel_DragOver" Drop="MemoryBrowser_Drop" />
                            </avalonDock:LayoutDocument>

                            <!-- Phase 3: Disassembler -->
                            <avalonDock:LayoutDocument Title="Disassembler" ContentId="disassembler">
                                <DockPanel x:Name="DisassemblerContent" Background="{DynamicResource SidebarBackground}"
                                         AllowDrop="True" DragOver="AddressPanel_DragOver" Drop="Disassembler_Drop">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6,8,4">
                                        <TextBlock Text="DISASSEMBLER" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Button Command="{Binding GoBackCommand}" Content="&#x25C0;" Padding="6,2" Style="{StaticResource ToolbarButton}" ToolTip="Back" />
                                        <Button Command="{Binding GoForwardCommand}" Content="&#x25B6;" Padding="6,2" Style="{StaticResource ToolbarButton}" ToolTip="Forward" Margin="2,0,8,0" />
                                        <TextBox Width="200" Text="{Binding GoToAddress, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                 BorderBrush="{DynamicResource InputBorder}" CaretBrush="{DynamicResource InputCaret}" VerticalContentAlignment="Center" Padding="4,2" />
                                        <Button Command="{Binding GoToAddressCommand}" Content="Go" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <TextBlock Text="{Binding CurrentFunctionLabel}" Foreground="{DynamicResource AccentForeground}" VerticalAlignment="Center" Margin="12,0,0,0" FontFamily="Consolas" FontSize="11" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,4">
                                        <TextBox Width="250" Text="{Binding SearchPattern, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                 BorderBrush="{DynamicResource InputBorder}" CaretBrush="{DynamicResource InputCaret}" VerticalContentAlignment="Center" Padding="4,2" />
                                        <Button Command="{Binding SearchInstructionsCommand}" Content="Search" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,8,0" />
                                        <Button Command="{Binding CopySelectedRangeCommand}" Content="Copy All" Padding="8,2" Style="{StaticResource ToolbarButton}" />
                                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" />
                                    </StackPanel>
                                    <ListView ItemsSource="{Binding Lines}" SelectedItem="{Binding SelectedLine}" FontFamily="Consolas" FontSize="12"
                                              Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                              BorderThickness="0">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="ToolTip">
                                                    <Setter.Value>
                                                        <MultiBinding StringFormat="{}{0}  {1}  {2} {3}&#x0a;Module: {4}&#x0a;Xref: {5}">
                                                            <Binding Path="Address" />
                                                            <Binding Path="HexBytes" />
                                                            <Binding Path="Mnemonic" />
                                                            <Binding Path="Operands" />
                                                            <Binding Path="ModuleOffset" TargetNullValue="(unknown)" />
                                                            <Binding Path="XrefLabel" TargetNullValue="—" />
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Address" Width="130" DisplayMemberBinding="{Binding Address}" />
                                                <GridViewColumn Header="Symbol" Width="180" DisplayMemberBinding="{Binding ModuleOffset}" />
                                                <GridViewColumn Header="Bytes" Width="120" DisplayMemberBinding="{Binding HexBytes}" />
                                                <GridViewColumn Header="Mnemonic" Width="80" DisplayMemberBinding="{Binding Mnemonic}" />
                                                <GridViewColumn Header="Operands" Width="200" DisplayMemberBinding="{Binding Operands}" />
                                                <GridViewColumn Header="Xref" Width="100" DisplayMemberBinding="{Binding XrefLabel}" />
                                                <GridViewColumn Header="Comment" Width="160" DisplayMemberBinding="{Binding Comment}" />
                                            </GridView>
                                        </ListView.View>
                                        <ListView.ContextMenu>
                                            <ContextMenu Background="{DynamicResource MenuBarBackground}" Foreground="{DynamicResource PrimaryForeground}">
                                                <MenuItem Header="Set Breakpoint" Command="{Binding SetBreakpointAtSelectedCommand}" />
                                                <MenuItem Header="Find What Writes" Command="{Binding FindWhatWritesCommand}" />
                                                <MenuItem Header="Generate Signature" Command="{Binding GenerateSignatureCommand}" />
                                                <Separator />
                                                <MenuItem Header="Follow Jump/Call" Command="{Binding FollowJumpCallCommand}" />
                                                <MenuItem Header="Edit Instruction..." Command="{Binding EditInstructionCommand}" />
                                                <Separator />
                                                <MenuItem Header="Browse Memory Here" Command="{Binding BrowseMemoryHereCommand}" />
                                                <MenuItem Header="Add to Address Table" Command="{Binding AddToTableCommand}" />
                                                <Separator />
                                                <MenuItem Header="Copy All" Command="{Binding CopySelectedRangeCommand}" />
                                                <Separator />
                                                <MenuItem Header="Ask AI About This" Command="{Binding AskAiCommand}" />
                                            </ContextMenu>
                                        </ListView.ContextMenu>
                                    </ListView>
                                </DockPanel>
                            </avalonDock:LayoutDocument>

                            <!-- Phase 3: Structure Dissector -->
                            <avalonDock:LayoutDocument Title="Structure Dissector" ContentId="structureDissector">
                                <DockPanel x:Name="StructureDissectorContent" Background="{DynamicResource SidebarBackground}"
                                         AllowDrop="True" DragOver="AddressPanel_DragOver" Drop="StructureDissector_Drop">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6,8,4">
                                        <TextBlock Text="STRUCTURE DISSECTOR" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <TextBox Width="180" Text="{Binding BaseAddress, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                 BorderBrush="{DynamicResource InputBorder}" CaretBrush="{DynamicResource InputCaret}" VerticalContentAlignment="Center" Padding="4,2" />
                                        <Button Command="{Binding DissectCommand}" Content="Dissect" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <TextBlock Text="Size:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                        <TextBox Width="60" Text="{Binding RegionSize, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                 BorderBrush="{DynamicResource InputBorder}" VerticalContentAlignment="Center" Padding="4,2" />
                                        <TextBlock Text="Hint:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                        <ComboBox ItemsSource="{Binding TypeHints}" SelectedItem="{Binding SelectedTypeHint}" Width="90"
                                                  Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" />
                                        <Button Command="{Binding FollowPointerCommand}" Content="Follow Ptr" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0" />
                                        <Button Command="{Binding ExportCStructCommand}" Content="Export C" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <Button Command="{Binding ExportCEStructCommand}" Content="Export CE" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,4">
                                        <TextBlock Text="Compare:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11" />
                                        <TextBox Width="180" Text="{Binding CompareAddress, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                 BorderBrush="{DynamicResource InputBorder}" CaretBrush="{DynamicResource InputCaret}" VerticalContentAlignment="Center" Padding="4,2" />
                                        <Button Command="{Binding CompareCommand}" Content="Compare" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" />
                                    </StackPanel>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" MaxHeight="250" />
                                        </Grid.RowDefinitions>
                                        <DataGrid Grid.Row="0" ItemsSource="{Binding Fields}" AutoGenerateColumns="False" SelectedItem="{Binding SelectedField}"
                                                  FontFamily="Consolas" FontSize="12" Background="{DynamicResource PanelBackground}"
                                                  Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0"
                                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                  RowBackground="{DynamicResource PanelBackground}" AlternatingRowBackground="{DynamicResource SidebarBackground}"
                                                  HeadersVisibility="Column" CanUserAddRows="False" SelectionMode="Single">
                                            <DataGrid.ContextMenu>
                                                <ContextMenu DataContext="{Binding DataContext, ElementName=StructureDissectorContent}" Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                                    <MenuItem Header="Copy Value" Command="{Binding CopyFieldValueCommand}" />
                                                    <MenuItem Header="Copy Offset" Command="{Binding CopyFieldOffsetCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="Browse Field Memory" Command="{Binding BrowseFieldMemoryCommand}" />
                                                    <MenuItem Header="Follow Pointer" Command="{Binding FollowPointerCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="Add Field to Address Table" Command="{Binding AddFieldToTableCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="Ask AI About This" Command="{Binding AskAiCommand}" />
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Offset" Binding="{Binding OffsetHex}" IsReadOnly="True" Width="80" />
                                                <DataGridTextColumn Header="Type" Binding="{Binding ProbableType}" IsReadOnly="True" Width="100" />
                                                <DataGridTextColumn Header="Value" Binding="{Binding DisplayValue}" IsReadOnly="True" Width="200" />
                                                <DataGridTextColumn Header="Conf." Binding="{Binding ConfidencePercent}" IsReadOnly="True" Width="60" />
                                                <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}" />
                                        <DataGrid Grid.Row="2" ItemsSource="{Binding CompareResults}" AutoGenerateColumns="False" IsReadOnly="True"
                                                  FontFamily="Consolas" FontSize="12" Background="{DynamicResource PanelBackground}"
                                                  Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0"
                                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                  HeadersVisibility="Column" CanUserAddRows="False">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDifferent}" Value="True">
                                                            <Setter Property="Foreground" Value="#FFE04040" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Offset" Binding="{Binding OffsetHex}" Width="80" />
                                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                                                <DataGridTextColumn Header="Value A" Binding="{Binding ValueA}" Width="200" />
                                                <DataGridTextColumn Header="Value B" Binding="{Binding ValueB}" Width="200" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </DockPanel>
                            </avalonDock:LayoutDocument>

                            <!-- Phase 3: Pointer Scanner -->
                            <avalonDock:LayoutDocument Title="Pointer Scanner" ContentId="pointerScanner">
                                <DockPanel x:Name="PointerScannerContent" Background="{DynamicResource SidebarBackground}">
                                    <StackPanel DockPanel.Dock="Top" Margin="8,6,8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="POINTER SCANNER" FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Text="Target:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <TextBox Width="180" Text="{Binding TargetAddress, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"
                                                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                     BorderBrush="{DynamicResource InputBorder}" CaretBrush="{DynamicResource InputCaret}" VerticalContentAlignment="Center" Padding="4,2" />
                                            <TextBlock Text="Depth:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                            <TextBox Width="40" Text="{Binding MaxDepth}" FontFamily="Consolas" FontSize="12"
                                                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                     BorderBrush="{DynamicResource InputBorder}" VerticalContentAlignment="Center" Padding="4,2" />
                                            <TextBlock Text="Max Offset:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                            <TextBox Width="80" Text="{Binding MaxOffset}" FontFamily="Consolas" FontSize="12"
                                                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                     BorderBrush="{DynamicResource InputBorder}" VerticalContentAlignment="Center" Padding="4,2" />
                                            <Button Command="{Binding ScanCommand}" Content="Scan" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0" />
                                            <Button Command="{Binding CancelScanCommand}" Content="Cancel" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0"
                                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Module filter:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11" />
                                            <TextBox Width="160" Text="{Binding ModuleFilter, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11"
                                                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                     BorderBrush="{DynamicResource InputBorder}" VerticalContentAlignment="Center" Padding="4,2"
                                                     ToolTip="Comma-separated module names to scan (e.g. game.dll, mono.dll). Leave empty for all." />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Command="{Binding AddSelectedToTableCommand}" Content="Add to Table" Padding="8,2" Style="{StaticResource ToolbarButton}" />
                                            <Button Command="{Binding ValidatePathsCommand}" Content="Validate" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                            <Button Command="{Binding ResumeScanCommand}" Content="Resume" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0"
                                                    IsEnabled="{Binding CanResume}" ToolTip="Resume a cancelled pointer scan" />
                                            <Button Command="{Binding SavePointerMapCommand}" Content="Save .PTR" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0"
                                                    ToolTip="Save pointer map for offline analysis" />
                                            <Button Command="{Binding LoadPointerMapCommand}" Content="Load .PTR" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0"
                                                    ToolTip="Load a saved pointer map" />
                                            <Button Command="{Binding ComparePointerMapsCommand}" Content="Compare" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0"
                                                    ToolTip="Compare two pointer map files" />
                                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>
                                    <ListView ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}" FontFamily="Consolas" FontSize="12"
                                              Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                              BorderThickness="0">
                                        <ListView.ContextMenu>
                                            <ContextMenu Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                                <MenuItem Header="Copy Pointer Chain" Command="{Binding CopyPathCommand}" />
                                                <MenuItem Header="Copy Resolved Address" Command="{Binding CopyResolvedAddressCommand}" />
                                                <Separator />
                                                <MenuItem Header="Browse Resolved Address" Command="{Binding BrowseResolvedCommand}" />
                                                <MenuItem Header="Disassemble Resolved" Command="{Binding DisassembleResolvedCommand}" />
                                                <Separator />
                                                <MenuItem Header="Add to Address Table" Command="{Binding AddSelectedToTableCommand}" />
                                                <Separator />
                                                <MenuItem Header="Ask AI About This" Command="{Binding AskAiCommand}" />
                                            </ContextMenu>
                                        </ListView.ContextMenu>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Pointer Chain" Width="400" DisplayMemberBinding="{Binding Chain}" />
                                                <GridViewColumn Header="Resolved" Width="160" DisplayMemberBinding="{Binding ResolvedAddress}" />
                                                <GridViewColumn Header="Module" Width="120" DisplayMemberBinding="{Binding ModuleName}" />
                                                <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </DockPanel>
                            </avalonDock:LayoutDocument>

                            <!-- Phase 3: Script Editor -->
                            <avalonDock:LayoutDocument Title="Script Editor" ContentId="scriptEditor">
                                <DockPanel x:Name="ScriptEditorContent" Background="{DynamicResource SidebarBackground}">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6,8,4">
                                        <TextBlock Text="SCRIPT EDITOR" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Button Command="{Binding NewScriptCommand}" Content="New" Padding="8,2" Style="{StaticResource ToolbarButton}" />
                                        <Button Command="{Binding SaveScriptCommand}" Content="Save" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <Button Command="{Binding DeleteScriptCommand}" Content="Delete" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,8,0" />
                                        <Button Command="{Binding ValidateCommand}" Content="Validate" Padding="8,2" Style="{StaticResource ToolbarButton}" />
                                        <Button Command="{Binding EnableScriptCommand}" Content="Enable" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <Button Command="{Binding DisableScriptCommand}" Content="Disable" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,8,0" />
                                        <Menu Background="Transparent" VerticalAlignment="Center">
                                            <MenuItem Header="Insert Template" Foreground="{DynamicResource PrimaryForeground}" FontSize="11">
                                                <MenuItem Header="AOB Inject" Command="{Binding InsertTemplateCommand}" CommandParameter="aob_inject" />
                                                <MenuItem Header="Code Cave" Command="{Binding InsertTemplateCommand}" CommandParameter="code_cave" />
                                                <MenuItem Header="NOP" Command="{Binding InsertTemplateCommand}" CommandParameter="nop" />
                                                <MenuItem Header="JMP" Command="{Binding InsertTemplateCommand}" CommandParameter="jmp" />
                                            </MenuItem>
                                        </Menu>
                                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" />
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <DockPanel Grid.Column="0">
                                            <Button DockPanel.Dock="Top" Command="{Binding RefreshScriptListCommand}" Content="Refresh" Padding="4,2" Margin="4"
                                                    Style="{StaticResource ToolbarButton}" />
                                            <ListBox ItemsSource="{Binding Scripts}" SelectedItem="{Binding SelectedScript}" DisplayMemberPath="Label"
                                                     Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                     BorderThickness="0" FontSize="12">
                                                <ListBox.InputBindings>
                                                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding LoadSelectedScriptCommand}" />
                                                </ListBox.InputBindings>
                                            </ListBox>
                                        </DockPanel>
                                        <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource BorderBrush}" />
                                        <DockPanel Grid.Column="2">
                                            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ValidationResult}" FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryForeground}" Margin="4" TextWrapping="Wrap" />
                                            <avalonEdit:TextEditor x:Name="ScriptTextEditor" FontFamily="Consolas" FontSize="12"
                                                     ShowLineNumbers="True" WordWrap="False"
                                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                     BorderThickness="0" />
                                        </DockPanel>
                                    </Grid>
                                </DockPanel>
                            </avalonDock:LayoutDocument>

                            <!-- Phase 3: Debugger -->
                            <avalonDock:LayoutDocument Title="Debugger" ContentId="debugger">
                                <DockPanel x:Name="DebuggerContent" Background="{DynamicResource SidebarBackground}">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6,8,4">
                                        <TextBlock Text="DEBUGGER" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Button Command="{Binding StepInCommand}" Content="Step In" Padding="8,2" Style="{StaticResource ToolbarButton}" IsEnabled="False" ToolTip="Phase 7" />
                                        <Button Command="{Binding StepOverCommand}" Content="Step Over" Padding="8,2" Style="{StaticResource ToolbarButton}" IsEnabled="False" ToolTip="Phase 7" Margin="4,0,0,0" />
                                        <Button Command="{Binding StepOutCommand}" Content="Step Out" Padding="8,2" Style="{StaticResource ToolbarButton}" IsEnabled="False" ToolTip="Phase 7" Margin="4,0,0,0" />
                                        <Button Command="{Binding ContinueCommand}" Content="Continue" Padding="8,2" Style="{StaticResource ToolbarButton}" IsEnabled="False" ToolTip="Phase 7" Margin="4,0,8,0" />
                                        <Button Command="{Binding RefreshBreakpointsCommand}" Content="Refresh BPs" Padding="8,2" Style="{StaticResource ToolbarButton}" />
                                        <Button Command="{Binding LoadHitDetailsCommand}" Content="Hit Log" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <Button Command="{Binding WalkCallStackCommand}" Content="Walk Stack" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0" />
                                        <TextBlock Text="|" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                        <TextBlock Text="Trace:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11" />
                                        <TextBox Width="120" Text="{Binding TraceAddress, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                 BorderBrush="{DynamicResource InputBorder}" VerticalContentAlignment="Center" Padding="4,2"
                                                 ToolTip="Address to trace from (hex)" />
                                        <TextBox Width="50" Text="{Binding TraceMaxInstructions}" FontFamily="Consolas" FontSize="11" Margin="4,0,0,0"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                 BorderBrush="{DynamicResource InputBorder}" VerticalContentAlignment="Center" Padding="4,2"
                                                 ToolTip="Max instructions to trace" />
                                        <Button Command="{Binding StartTraceCommand}" Content="Trace" Padding="8,2" Style="{StaticResource ToolbarButton}" Margin="4,0,0,0"
                                                ToolTip="Trace instruction execution from address" />
                                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" />
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <!-- Top-left: Registers -->
                                        <DockPanel Grid.Column="0" Grid.Row="0">
                                            <TextBlock DockPanel.Dock="Top" Text="REGISTERS" FontWeight="SemiBold" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryForeground}" Margin="4,2" />
                                            <DataGrid ItemsSource="{Binding Registers}" AutoGenerateColumns="False" IsReadOnly="True"
                                                      FontFamily="Consolas" FontSize="12" Background="{DynamicResource PanelBackground}"
                                                      Foreground="{DynamicResource PrimaryForeground}" BorderThickness="0"
                                                      HeadersVisibility="Column" CanUserAddRows="False">
                                                <DataGrid.RowStyle>
                                                    <Style TargetType="DataGridRow">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                                                <Setter Property="Foreground" Value="#FFE04040" />
                                                                <Setter Property="FontWeight" Value="Bold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGrid.RowStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Register" Binding="{Binding Name}" Width="100" />
                                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                        <!-- Top-right: Call Stack -->
                                        <DockPanel Grid.Column="2" Grid.Row="0">
                                            <TextBlock DockPanel.Dock="Top" Text="CALL STACK" FontWeight="SemiBold" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryForeground}" Margin="4,2" />
                                            <ListView ItemsSource="{Binding CallStack}" FontFamily="Consolas" FontSize="11"
                                                      Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                      BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="#" Width="30" DisplayMemberBinding="{Binding FrameIndex}" />
                                                        <GridViewColumn Header="IP" Width="150" DisplayMemberBinding="{Binding InstructionPointer}" />
                                                        <GridViewColumn Header="Module+Offset" Width="200" DisplayMemberBinding="{Binding ModuleOffset}" />
                                                        <GridViewColumn Header="Return" Width="150" DisplayMemberBinding="{Binding ReturnAddress}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </DockPanel>
                                        <GridSplitter Grid.ColumnSpan="3" Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                                                      Background="{DynamicResource BorderBrush}" />
                                        <!-- Bottom-left: Breakpoint Hits -->
                                        <DockPanel Grid.Column="0" Grid.Row="2">
                                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2">
                                                <TextBlock Text="BREAKPOINT HITS" FontWeight="SemiBold" FontSize="10"
                                                           Foreground="{DynamicResource SecondaryForeground}" />
                                                <TextBlock Text="  (select a hit to view its registers)" FontSize="10"
                                                           Foreground="{DynamicResource TertiaryForeground}" />
                                            </StackPanel>
                                            <ListView ItemsSource="{Binding HitDetails}" SelectedItem="{Binding SelectedHit}"
                                                      FontFamily="Consolas" FontSize="11"
                                                      Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                      BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="BP ID" Width="80" DisplayMemberBinding="{Binding BreakpointId}" />
                                                        <GridViewColumn Header="Address" Width="150" DisplayMemberBinding="{Binding Address}" />
                                                        <GridViewColumn Header="Thread" Width="60" DisplayMemberBinding="{Binding ThreadId}" />
                                                        <GridViewColumn Header="Time" Width="120" DisplayMemberBinding="{Binding Timestamp}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </DockPanel>
                                        <!-- Bottom-right: Trace Results -->
                                        <DockPanel Grid.Column="2" Grid.Row="2">
                                            <TextBlock DockPanel.Dock="Top" Text="TRACE RESULTS" FontWeight="SemiBold" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryForeground}" Margin="4,2" />
                                            <ListView ItemsSource="{Binding TraceEntries}" FontFamily="Consolas" FontSize="11"
                                                      Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                      BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Address" Width="140" DisplayMemberBinding="{Binding Address}" />
                                                        <GridViewColumn Header="Instruction" Width="250" DisplayMemberBinding="{Binding Disassembly}" />
                                                        <GridViewColumn Header="TID" Width="50" DisplayMemberBinding="{Binding ThreadId}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </DockPanel>
                                        <GridSplitter Grid.Column="1" Grid.Row="0" Width="4" Background="{DynamicResource BorderBrush}" />
                                    </Grid>
                                </DockPanel>
                            </avalonDock:LayoutDocument>

                            <!-- Phase 8: Lua Console -->
                            <avalonDock:LayoutDocument Title="Lua Console" ContentId="luaConsole">
                                <DockPanel x:Name="LuaConsoleContent" Background="{DynamicResource SidebarBackground}">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,6,8,4">
                                        <TextBlock Text="LUA CONSOLE" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Button Content="Execute" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"
                                                Command="{Binding ExecuteCommand}" ToolTip="Execute script (Enter)" />
                                        <Button Content="Eval" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"
                                                Command="{Binding EvaluateLineCommand}" ToolTip="Evaluate expression (Ctrl+Enter)" />
                                        <Button Content="Clear" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"
                                                Command="{Binding ClearCommand}" />
                                        <Button Content="Reset" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0"
                                                Command="{Binding ResetEngineCommand}" ToolTip="Reset Lua state" />
                                    </StackPanel>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- History -->
                                        <ListView Grid.Row="0" ItemsSource="{Binding History}" Margin="4,0,4,4"
                                                  Background="{DynamicResource InputBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                  BorderBrush="{DynamicResource BorderBrush}" FontFamily="Consolas" FontSize="12">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <Run Text="{Binding Timestamp, Mode=OneTime}" Foreground="{DynamicResource TertiaryForeground}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding Text, Mode=OneTime}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <!-- Input -->
                                        <TextBox Grid.Row="1" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="4,0,4,4" Padding="6" FontFamily="Consolas" FontSize="12"
                                                 AcceptsReturn="True" MinHeight="60" MaxHeight="150"
                                                 Background="{DynamicResource InputBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                 BorderBrush="{DynamicResource BorderBrush}"
                                                 ToolTip="Enter Lua code. Press Enter to execute." />
                                    </Grid>
                                </DockPanel>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>

                        <avalonDock:LayoutAnchorablePane DockHeight="472">
                            <avalonDock:LayoutAnchorable Title="Scanner" ContentId="scanner">
                                <Grid x:Name="ScannerContent" Background="{DynamicResource SidebarBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="8,8,8,4">
                                        <TextBlock Text="MEMORY SCANNER" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,6,0">
                                                <TextBlock Text="Scan type" FontSize="11" Margin="0,0,0,3" />
                                                <ComboBox x:Name="ScanTypeComboBox" Loaded="OnScanTypeComboBoxLoaded"
                                                         SelectedItem="{Binding SelectedScanType, Mode=TwoWay}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Data type" FontSize="11" Margin="0,0,0,3" />
                                                <ComboBox x:Name="ScanDataTypeComboBox" Loaded="OnScanDataTypeComboBoxLoaded"
                                                         SelectedItem="{Binding SelectedDataType, Mode=TwoWay}" FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Value" FontSize="11" Margin="0,6,0,3" />
                                        <TextBox x:Name="ScanValueTextBox" Text="{Binding ScanValue, UpdateSourceTrigger=PropertyChanged}" FontSize="12" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Button Padding="8,3" Margin="0,0,6,0" Command="{Binding StartNewScanCommand}" Content="New scan" FontSize="11" />
                                            <Button Padding="8,3" Margin="0,0,6,0" Command="{Binding RefineScanCommand}" Content="Next scan" FontSize="11" />
                                            <Button Padding="8,3" Margin="0,0,6,0" Command="{Binding UndoScanCommand}" Content="Undo"
                                                    FontSize="11" Style="{StaticResource ToolbarButton}" IsEnabled="{Binding CanUndo}" ToolTip="Undo last refinement" />
                                            <Button Padding="8,3" Margin="0,0,6,0" Command="{Binding ResetScanCommand}" Content="Reset"
                                                    FontSize="11" Style="{StaticResource ToolbarButton}" />
                                            <Button Padding="8,3" Command="{Binding AddSelectedToTableCommand}" Content="Add to table"
                                                    FontSize="11" Style="{StaticResource ToolbarButton}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <CheckBox Content="Hex" IsChecked="{Binding ShowAsHex}" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0"
                                                      ToolTip="Display scan results in hexadecimal" />
                                            <CheckBox Content="Writable only" IsChecked="{Binding WritableOnly}" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0"
                                                      ToolTip="Only scan writable memory regions" />
                                            <TextBlock Text="Align:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0" />
                                            <ComboBox SelectedValue="{Binding Alignment}" SelectedValuePath="Tag" FontSize="11" Width="60" VerticalContentAlignment="Center" Margin="0,0,8,0"
                                                      ToolTip="Scan alignment in bytes (Auto = use value size)">
                                                <ComboBoxItem Tag="0" Content="Auto" IsSelected="True" />
                                                <ComboBoxItem Tag="1" Content="1" />
                                                <ComboBoxItem Tag="2" Content="2" />
                                                <ComboBoxItem Tag="4" Content="4" />
                                                <ComboBoxItem Tag="8" Content="8" />
                                            </ComboBox>
                                            <TextBlock Text="Epsilon:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0" />
                                            <TextBox Width="60" Text="{Binding FloatEpsilon, UpdateSourceTrigger=PropertyChanged}" FontSize="11" VerticalContentAlignment="Center" Padding="4,2"
                                                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                     BorderBrush="{DynamicResource InputBorder}" ToolTip="Float comparison tolerance (e.g. 0.1). Leave empty for exact match." />
                                        </StackPanel>
                                        <Border Background="{DynamicResource MenuBarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="3" Padding="8" Margin="0,6,0,0">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" FontSize="12"
                                                           Text="{Binding ScanStatus, TargetNullValue=No scan active}" />
                                                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource SecondaryForeground}" FontSize="11"
                                                           Text="{Binding ScanDetails}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <ListView Grid.Row="1" x:Name="ScanResultsList" ItemsSource="{Binding ScanResults}"
                                              SelectedItem="{Binding SelectedScanResult, Mode=TwoWay}"
                                              Background="{DynamicResource PanelBackground}" FontSize="11" BorderThickness="0"
                                              PreviewMouseLeftButtonDown="ScanResults_PreviewMouseLeftButtonDown"
                                              PreviewMouseMove="ScanResults_PreviewMouseMove"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.CanContentScroll="True">
                                        <ListView.ContextMenu>
                                            <ContextMenu Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                                <MenuItem Header="Copy Address" Command="{Binding CopyAddressCommand}" />
                                                <MenuItem Header="Copy Value" Command="{Binding CopyValueCommand}" />
                                                <Separator />
                                                <MenuItem Header="Browse Memory" Command="{Binding BrowseMemoryCommand}" />
                                                <MenuItem Header="Disassemble Here" Command="{Binding DisassembleHereCommand}" />
                                                <Separator />
                                                <MenuItem Header="Add to Address Table" Command="{Binding AddSelectedToTableCommand}" />
                                                <Separator />
                                                <MenuItem Header="Ask AI About This" Command="{Binding AskAiCommand}" />
                                            </ContextMenu>
                                        </ListView.ContextMenu>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Address" Width="130"
                                                                DisplayMemberBinding="{Binding Address}" />
                                                <GridViewColumn Header="Value" Width="100"
                                                                DisplayMemberBinding="{Binding CurrentValue}" />
                                                <GridViewColumn Header="Previous" Width="100"
                                                                DisplayMemberBinding="{Binding PreviousValue}" />
                                                <GridViewColumn Header="Hex" Width="100"
                                                                DisplayMemberBinding="{Binding HexBytes}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </avalonDock:LayoutAnchorable>
                            <!-- ═══ Output Log ═══ -->
                            <avalonDock:LayoutAnchorable Title="Output" ContentId="output">
                                <Grid x:Name="OutputContent" Background="{DynamicResource SidebarBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Margin="8,6,8,4">
                                        <TextBlock Text="OUTPUT LOG" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" />
                                        <Button DockPanel.Dock="Right" Content="Clear" FontSize="11"
                                                Style="{StaticResource ToolbarButton}" Command="{Binding ClearCommand}"
                                                HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <ListView Grid.Row="1" x:Name="OutputLogList"
                                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                              Background="{DynamicResource PanelBackground}" FontSize="11"
                                              BorderThickness="0"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                        <ListView.ContextMenu>
                                            <ContextMenu Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                                <MenuItem Header="Copy Line" Command="{Binding CopyLineCommand}" />
                                                <MenuItem Header="Copy All" Command="{Binding CopyAllCommand}" />
                                                <Separator />
                                                <MenuItem Header="Clear" Command="{Binding ClearCommand}" />
                                            </ContextMenu>
                                        </ListView.ContextMenu>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Time" Width="75"
                                                                DisplayMemberBinding="{Binding Timestamp}" />
                                                <GridViewColumn Header="Source" Width="70"
                                                                DisplayMemberBinding="{Binding Source}" />
                                                <GridViewColumn Header="Level" Width="50"
                                                                DisplayMemberBinding="{Binding Level}" />
                                                <GridViewColumn Header="Message" Width="500"
                                                                DisplayMemberBinding="{Binding Message}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </avalonDock:LayoutAnchorable>

                            <!-- ═══ Breakpoints (3 sub-tabs) ═══ -->
                            <avalonDock:LayoutAnchorable Title="Breakpoints" ContentId="breakpoints">
                                <TabControl x:Name="BreakpointsContent" Background="{DynamicResource SidebarBackground}" BorderThickness="0">
                                    <TabItem Header="Breakpoints">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                                <Button Content="Refresh" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RefreshBreakpointsCommand}" />
                                                <Button Content="Remove" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RemoveSelectedCommand}" />
                                                <Button Content="Remove All" FontSize="11" Style="{StaticResource ToolbarButton}" Command="{Binding RemoveAllCommand}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="8,2,8,4">
                                                <TextBox Text="{Binding ConditionalBpAddress, UpdateSourceTrigger=PropertyChanged}" Width="100" FontSize="11" VerticalContentAlignment="Center"
                                                         Padding="4,2" ToolTip="Address (hex)" Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                                                         BorderBrush="{DynamicResource InputBorder}" />
                                                <TextBox Text="{Binding ConditionExpression, UpdateSourceTrigger=PropertyChanged}" Width="140" FontSize="11" VerticalContentAlignment="Center"
                                                         Padding="4,2" Margin="4,0,0,0" ToolTip="Condition (e.g. RAX==100, [0x1000]!=0, hitcount>=5)"
                                                         Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" BorderBrush="{DynamicResource InputBorder}" />
                                                <TextBox Text="{Binding ThreadFilterText, UpdateSourceTrigger=PropertyChanged}" Width="50" FontSize="11" VerticalContentAlignment="Center"
                                                         Padding="4,2" Margin="4,0,0,0" ToolTip="Thread ID (optional)"
                                                         Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" BorderBrush="{DynamicResource InputBorder}" />
                                                <Button Content="Set Conditional BP" FontSize="11" Margin="4,0,0,0" Command="{Binding SetConditionalBreakpointCommand}" />
                                            </StackPanel>
                                            <ListView Grid.Row="1" ItemsSource="{Binding Breakpoints}" SelectedItem="{Binding SelectedBreakpoint}"
                                                      Background="{DynamicResource PanelBackground}" FontSize="11" FontFamily="Consolas" BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Address" Width="130" DisplayMemberBinding="{Binding Address}" />
                                                        <GridViewColumn Header="Type" Width="90" DisplayMemberBinding="{Binding Type}" />
                                                        <GridViewColumn Header="Mode" Width="80" DisplayMemberBinding="{Binding Mode}" />
                                                        <GridViewColumn Header="Hits" Width="50" DisplayMemberBinding="{Binding HitCount}" />
                                                        <GridViewColumn Header="Condition" Width="120" DisplayMemberBinding="{Binding Condition}" />
                                                        <GridViewColumn Header="Thread" Width="50" DisplayMemberBinding="{Binding ThreadFilter}" />
                                                        <GridViewColumn Header="Status" Width="70" DisplayMemberBinding="{Binding Status}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="Hit Log">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                                <Button Content="Refresh" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RefreshHitLogCommand}" />
                                                <TextBlock Text="{Binding HitLogStatus}" VerticalAlignment="Center" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryForeground}" />
                                            </StackPanel>
                                            <ListView Grid.Row="1" ItemsSource="{Binding HitLog}"
                                                      Background="{DynamicResource PanelBackground}" FontSize="11" FontFamily="Consolas" BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Time" Width="100" DisplayMemberBinding="{Binding Timestamp}" />
                                                        <GridViewColumn Header="Address" Width="130" DisplayMemberBinding="{Binding Address}" />
                                                        <GridViewColumn Header="Thread" Width="70" DisplayMemberBinding="{Binding ThreadId}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="Code Caves">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                                <TextBox Text="{Binding CodeCaveAddress, UpdateSourceTrigger=PropertyChanged}" Width="140" FontSize="11" VerticalContentAlignment="Center" ToolTip="Address to hook (hex)" />
                                                <Button Content="Install Hook" FontSize="11" Margin="4,0,4,0" Command="{Binding InstallHookCommand}" />
                                                <Button Content="Remove" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RemoveSelectedHookCommand}" />
                                                <Button Content="Refresh" FontSize="11" Style="{StaticResource ToolbarButton}" Command="{Binding RefreshHooksCommand}" />
                                            </StackPanel>
                                            <ListView Grid.Row="1" ItemsSource="{Binding CodeCaveHooks}" SelectedItem="{Binding SelectedCodeCaveHook}"
                                                      Background="{DynamicResource PanelBackground}" FontSize="11" FontFamily="Consolas" BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Original Addr" Width="130" DisplayMemberBinding="{Binding OriginalAddress}" />
                                                        <GridViewColumn Header="Cave Addr" Width="130" DisplayMemberBinding="{Binding CaveAddress}" />
                                                        <GridViewColumn Header="Active" Width="60" DisplayMemberBinding="{Binding IsActive}" />
                                                        <GridViewColumn Header="Hits" Width="60" DisplayMemberBinding="{Binding HitCount}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </avalonDock:LayoutAnchorable>

                            <!-- ═══ Scripts ═══ -->
                            <avalonDock:LayoutAnchorable Title="Scripts" ContentId="scripts">
                                <Grid x:Name="ScriptsContent" Background="{DynamicResource SidebarBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                        <Button Content="Refresh" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RefreshCommand}" />
                                        <Button Content="Enable" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding EnableSelectedCommand}" />
                                        <Button Content="Disable" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding DisableSelectedCommand}" />
                                        <Button Content="Toggle" FontSize="11" Style="{StaticResource ToolbarButton}" Command="{Binding ToggleSelectedCommand}" />
                                    </StackPanel>
                                    <ListView Grid.Row="1" ItemsSource="{Binding Scripts}" SelectedItem="{Binding SelectedScript}"
                                              Background="{DynamicResource PanelBackground}" FontSize="11" BorderThickness="0">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding StatusText}" />
                                                <GridViewColumn Header="Name" Width="250" DisplayMemberBinding="{Binding Label}" />
                                                <GridViewColumn Header="ID" Width="100" DisplayMemberBinding="{Binding Id}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </avalonDock:LayoutAnchorable>

                            <!-- ═══ Snapshots ═══ -->
                            <avalonDock:LayoutAnchorable Title="Snapshots" ContentId="snapshots">
                                <Grid x:Name="SnapshotsContent" Background="{DynamicResource SidebarBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="120" FontSize="11" VerticalContentAlignment="Center" ToolTip="Base address (hex)" />
                                        <TextBox Text="{Binding Length, UpdateSourceTrigger=PropertyChanged}" Width="60" FontSize="11" VerticalContentAlignment="Center" ToolTip="Length (bytes)" Margin="4,0,0,0" />
                                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Width="100" FontSize="11" VerticalContentAlignment="Center" ToolTip="Label (optional)" Margin="4,0,0,0" />
                                        <Button Content="Capture" FontSize="11" Margin="4,0,4,0" Command="{Binding CaptureCommand}" />
                                        <Button Content="Compare" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding CompareCommand}" ToolTip="Select two snapshots" />
                                        <Button Content="Compare Live" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding CompareWithLiveCommand}" />
                                        <Button Content="Delete" FontSize="11" Style="{StaticResource ToolbarButton}" Command="{Binding DeleteSelectedCommand}" />
                                    </StackPanel>
                                    <ListView Grid.Row="1" x:Name="SnapshotList" ItemsSource="{Binding Snapshots}" SelectedItem="{Binding SelectedSnapshot}" MaxHeight="120"
                                              Background="{DynamicResource PanelBackground}" FontSize="11" BorderThickness="0" SelectionMode="Extended">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Label" Width="150" DisplayMemberBinding="{Binding Label}" />
                                                <GridViewColumn Header="Address" Width="120" DisplayMemberBinding="{Binding Address}" />
                                                <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding Size}" />
                                                <GridViewColumn Header="Captured" Width="140" DisplayMemberBinding="{Binding CapturedAt}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <ListView Grid.Row="2" ItemsSource="{Binding DiffItems}"
                                              Background="{DynamicResource PanelBackground}" FontSize="11" FontFamily="Consolas" BorderThickness="0">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Offset" Width="80" DisplayMemberBinding="{Binding Offset}" />
                                                <GridViewColumn Header="Old" Width="120" DisplayMemberBinding="{Binding OldValue}" />
                                                <GridViewColumn Header="New" Width="120" DisplayMemberBinding="{Binding NewValue}" />
                                                <GridViewColumn Header="Interpretation" Width="250" DisplayMemberBinding="{Binding Interpretation}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </avalonDock:LayoutAnchorable>

                            <!-- ═══ Find Results ═══ -->
                            <avalonDock:LayoutAnchorable Title="Find Results" ContentId="findResults">
                                <Grid x:Name="FindResultsContent" Background="{DynamicResource SidebarBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <DockPanel Margin="8,6,8,4">
                                        <TextBlock Text="FIND RESULTS" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryForeground}" />
                                        <Button DockPanel.Dock="Right" Content="Clear" FontSize="11"
                                                Style="{StaticResource ToolbarButton}" Command="{Binding ClearCommand}" HorizontalAlignment="Right" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryForeground}" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                    </DockPanel>
                                    <ListView Grid.Row="1" ItemsSource="{Binding Results}"
                                              Background="{DynamicResource PanelBackground}" FontSize="11" FontFamily="Consolas" BorderThickness="0">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Address" Width="130" DisplayMemberBinding="{Binding Address}" />
                                                <GridViewColumn Header="Instruction" Width="250" DisplayMemberBinding="{Binding Instruction}" />
                                                <GridViewColumn Header="Module" Width="120" DisplayMemberBinding="{Binding Module}" />
                                                <GridViewColumn Header="Context" Width="200" DisplayMemberBinding="{Binding Context}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </avalonDock:LayoutAnchorable>

                            <!-- ═══ Hotkeys ═══ -->
                            <avalonDock:LayoutAnchorable Title="Hotkeys" ContentId="hotkeys">
                                <Grid x:Name="HotkeysContent" Background="{DynamicResource SidebarBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                        <Button Content="Refresh" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RefreshCommand}" />
                                        <Button Content="Remove" FontSize="11" Style="{StaticResource ToolbarButton}" Command="{Binding RemoveSelectedCommand}" />
                                    </StackPanel>
                                    <ListView Grid.Row="1" ItemsSource="{Binding Hotkeys}" SelectedItem="{Binding SelectedHotkey}"
                                              Background="{DynamicResource PanelBackground}" FontSize="11" BorderThickness="0">
                                        <ListView.ContextMenu>
                                            <ContextMenu Background="{DynamicResource ContextMenuBackground}" Foreground="{DynamicResource ContextMenuForeground}" BorderBrush="{DynamicResource ContextMenuBorder}">
                                                <MenuItem Header="Remove Selected" Command="{Binding RemoveSelectedCommand}" />
                                                <Separator />
                                                <MenuItem Header="Refresh" Command="{Binding RefreshCommand}" />
                                            </ContextMenu>
                                        </ListView.ContextMenu>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="ID" Width="40" DisplayMemberBinding="{Binding Id}" />
                                                <GridViewColumn Header="Hotkey" Width="120" DisplayMemberBinding="{Binding KeyCombo}" />
                                                <GridViewColumn Header="Description" Width="300" DisplayMemberBinding="{Binding Description}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </avalonDock:LayoutAnchorable>

                            <!-- ═══ Journal (2 sub-tabs) ═══ -->
                            <avalonDock:LayoutAnchorable Title="Journal" ContentId="journal">
                                <TabControl x:Name="JournalContent" Background="{DynamicResource SidebarBackground}" BorderThickness="0">
                                    <TabItem Header="Patch History">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                                <Button Content="Refresh" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RefreshPatchHistoryCommand}" />
                                                <Button Content="Undo Last" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding UndoPatchCommand}" />
                                                <Button Content="Rollback All" FontSize="11" Style="{StaticResource ToolbarButton}" Command="{Binding RollbackAllCommand}" Foreground="OrangeRed" />
                                            </StackPanel>
                                            <ListView Grid.Row="1" ItemsSource="{Binding PatchHistory}"
                                                      Background="{DynamicResource PanelBackground}" FontSize="11" FontFamily="Consolas" BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Time" Width="100" DisplayMemberBinding="{Binding Timestamp}" />
                                                        <GridViewColumn Header="Address" Width="130" DisplayMemberBinding="{Binding Address}" />
                                                        <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding DataType}" />
                                                        <GridViewColumn Header="New Value" Width="100" DisplayMemberBinding="{Binding NewValue}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="Operations">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="8,6,8,4">
                                                <Button Content="Refresh" FontSize="11" Style="{StaticResource ToolbarButton}" Margin="0,0,4,0" Command="{Binding RefreshJournalCommand}" />
                                                <Button Content="Rollback Selected" FontSize="11" Style="{StaticResource ToolbarButton}" Command="{Binding RollbackSelectedEntryCommand}" />
                                            </StackPanel>
                                            <ListView Grid.Row="1" ItemsSource="{Binding JournalEntries}" SelectedItem="{Binding SelectedJournalEntry}"
                                                      Background="{DynamicResource PanelBackground}" FontSize="11" BorderThickness="0">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Time" Width="100" DisplayMemberBinding="{Binding Timestamp}" />
                                                        <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding OperationType}" />
                                                        <GridViewColumn Header="Address" Width="130" DisplayMemberBinding="{Binding Address}" />
                                                        <GridViewColumn Header="Mode" Width="80" DisplayMemberBinding="{Binding Mode}" />
                                                        <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}" />
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutPanel>

                    <!-- Right sidebar: AI Operator -->
                    <avalonDock:LayoutAnchorablePane DockWidth="320">
                        <avalonDock:LayoutAnchorable Title="AI Operator" ContentId="aiOperator">
                            <DockPanel x:Name="AiOperatorContent" Background="{DynamicResource SidebarBackground}"
                                       AllowDrop="True" Drop="AiPanel_Drop" DragOver="AiPanel_DragOver">

                                <!-- Header bar -->
                                <Grid DockPanel.Dock="Top" Margin="8,8,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                        <Run Text="AI OPERATOR" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryForeground}" />
                                        <Run Text="  (drag items here)" FontSize="9" Foreground="{DynamicResource TertiaryForeground}" />
                                    </TextBlock>
                                    <Button Grid.Column="2" Content="＋ New" Padding="8,2" Margin="0,0,4,0"
                                            FontSize="10" ToolTip="New Chat" Click="NewAiChat"
                                            Style="{StaticResource ToolbarButton}" />
                                    <Button Grid.Column="3" Content="Export" Padding="8,2" Margin="0,0,4,0"
                                            FontSize="10" ToolTip="Export chat to Markdown file" Click="ExportAiChat"
                                            Style="{StaticResource ToolbarButton}" />
                                    <ToggleButton x:Name="ChatHistoryToggle" Grid.Column="4" Content="History"
                                                  Padding="8,2" FontSize="10" ToolTip="Toggle chat history"
                                                  IsChecked="{Binding IsChatHistoryVisible}"
                                                  Background="{DynamicResource InputBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderBrush="{DynamicResource BorderBrush}" />
                                </Grid>

                                <!-- Chat History Popup (floaty overlay) -->
                                <Popup x:Name="ChatHistoryPanel" StaysOpen="False" Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=ChatHistoryToggle}" AllowsTransparency="True"
                                       IsOpen="{Binding IsChatHistoryVisible, Mode=TwoWay}"
                                       Opened="ChatHistoryPanel_Opened">
                                <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="0" Width="340" MaxHeight="520">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" />
                                    </Border.Effect>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="RECENT CHATS" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TertiaryForeground}" Margin="12,10,12,4" />
                                        <TextBox x:Name="ChatSearchBox" DockPanel.Dock="Top" Margin="12,0,12,6"
                                                 Padding="6,4" FontSize="11" Background="{DynamicResource InputBackground}" Foreground="{DynamicResource PrimaryForeground}"
                                                 BorderBrush="{DynamicResource BorderBrush}" Tag="Search chats..."
                                                 GotFocus="ChatSearchBox_GotFocus" LostFocus="ChatSearchBox_LostFocus"
                                                 TextChanged="ChatSearchBox_TextChanged" />
                                        <ListView x:Name="ChatHistoryList" Background="{DynamicResource PanelBackground}" BorderThickness="0"
                                                  ItemsSource="{Binding ChatHistory}"
                                                  MouseDoubleClick="ChatHistoryList_DoubleClick">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Padding" Value="8,4" />
                                                    <Setter Property="Margin" Value="0" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListViewItem">
                                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                                        Background="Transparent" BorderThickness="0,0,0,1"
                                                                        BorderBrush="{DynamicResource BorderBrush}">
                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ContextMenu>
                                                <ContextMenu Background="{DynamicResource MenuBarBackground}" Foreground="{DynamicResource PrimaryForeground}" BorderBrush="{DynamicResource BorderBrush}">
                                                    <MenuItem Header="Open" Click="ChatCtx_Open" />
                                                    <MenuItem Header="Rename" Click="ChatCtx_Rename" />
                                                    <Separator />
                                                    <MenuItem Header="Delete" Click="ChatCtx_Delete" />
                                                </ContextMenu>
                                            </ListView.ContextMenu>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Title}"
                                                                   FontSize="12" Foreground="{DynamicResource PrimaryForeground}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TimeAgo}"
                                                                   FontSize="10" Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                                   Text="{Binding Preview}" FontSize="10" Foreground="{DynamicResource SecondaryForeground}"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </DockPanel>
                                </Border>
                                </Popup>

                                <!-- Bottom: Attachments + Input + Controls + Status -->
                                <DockPanel DockPanel.Dock="Bottom" Margin="8,4,8,8">
                                    <!-- Status bar at very bottom -->
                                    <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="AiStatusText" Grid.Column="0" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SecondaryForeground}" Text="{Binding StatusText}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="AiChatTitleText" Grid.Column="1" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TertiaryForeground}" FontSize="10" TextTrimming="CharacterEllipsis"
                                                       MaxWidth="120" Text="{Binding ChatTitle}" ToolTip="{Binding ChatTitle}" />
                                        </Grid>
                                        <!-- Session indicators -->
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding BudgetStatus}" FontSize="9"
                                                       Foreground="{DynamicResource TertiaryForeground}"
                                                       Margin="0,0,10,0" ToolTip="Session cost estimate" />
                                            <TextBlock Text="{Binding MemoryStatus}" FontSize="9"
                                                       Foreground="{DynamicResource TertiaryForeground}"
                                                       Margin="0,0,10,0" ToolTip="Agent memory entries" />
                                            <TextBlock Text="{Binding McpStatus}" FontSize="9"
                                                       Foreground="{DynamicResource TertiaryForeground}"
                                                       Margin="0,0,10,0" ToolTip="MCP server connections" />
                                            <TextBlock Text="{Binding CacheStatus}" FontSize="9"
                                                       Foreground="{DynamicResource TertiaryForeground}"
                                                       ToolTip="Prompt cache hit rate" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Main input container -->
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Background="{DynamicResource PanelBackground}" Padding="0">
                                        <DockPanel>
                                            <!-- Attachment chips area (hidden when no attachments) -->
                                            <ItemsControl x:Name="AttachmentChips" DockPanel.Dock="Top" Margin="12,8,12,0"
                                                          ItemsSource="{Binding Attachments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource InputBackground}" CornerRadius="6"
                                                                Padding="8,4" Margin="0,0,6,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                                MaxWidth="200" ToolTip="{Binding FullText}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Image thumbnail (only shown for image attachments) -->
                                                                <Image Grid.Column="0" Source="{Binding Thumbnail}" MaxHeight="28" MaxWidth="40"
                                                                       Margin="0,0,6,0" VerticalAlignment="Center"
                                                                       Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}" />
                                                                <StackPanel Grid.Column="1" MaxWidth="140">
                                                                    <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource PrimaryForeground}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding Preview}" FontSize="9"
                                                                               Foreground="{DynamicResource SecondaryForeground}" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                                <Button Grid.Column="2" Content="✕" FontSize="9" Padding="4,0" Margin="4,0,0,0"
                                                                        Background="Transparent" Foreground="{DynamicResource SecondaryForeground}"
                                                                        BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                                                                        Click="RemoveAttachment_Click" Tag="{Binding Id}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Bottom controls bar -->
                                            <Grid DockPanel.Dock="Bottom" Margin="8,4,8,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- + attach button -->
                                                <Button Grid.Column="0" Content="＋" FontSize="16" Padding="6,0" Margin="0,0,4,0"
                                                        Background="Transparent" Foreground="{DynamicResource SecondaryForeground}"
                                                        BorderThickness="0" Cursor="Hand" ToolTip="Attach context"
                                                        Click="AttachContext_Click" VerticalAlignment="Center" />

                                                <!-- Permission mode selector -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <Button x:Name="PermissionModeButton" Click="PermissionMode_Click"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2"
                                                            ToolTip="Permission mode — controls tool access policy">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock x:Name="PermissionModeIcon" Text="🛡" FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0" />
                                                            <TextBlock Text="{Binding PermissionModeDisplay}" FontSize="11"
                                                                       Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" />
                                                            <TextBlock Text=" ▾" FontSize="9" Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Popup x:Name="PermissionModePopup" StaysOpen="False" Placement="Top"
                                                           PlacementTarget="{Binding ElementName=PermissionModeButton}" AllowsTransparency="True">
                                                        <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1" CornerRadius="6" Padding="4" MinWidth="160">
                                                            <StackPanel>
                                                                <Button Content="Normal — dangerous tools need approval" FontSize="11" Tag="Normal"
                                                                        Padding="10,6" HorizontalContentAlignment="Left"
                                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                        Click="PermissionModeItem_Click" />
                                                                <Button Content="Read Only — only read-only tools allowed" FontSize="11" Tag="ReadOnly"
                                                                        Padding="10,6" HorizontalContentAlignment="Left"
                                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                        Click="PermissionModeItem_Click" />
                                                                <Button Content="Plan Only — read-only + planning tools" FontSize="11" Tag="PlanOnly"
                                                                        Padding="10,6" HorizontalContentAlignment="Left"
                                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                        Click="PermissionModeItem_Click" />
                                                                <Button Content="Unrestricted — all tools auto-approved" FontSize="11" Tag="Unrestricted"
                                                                        Padding="10,6" HorizontalContentAlignment="Left"
                                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                        Click="PermissionModeItem_Click" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </StackPanel>

                                                <!-- Model selector dropdown -->
                                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Button x:Name="ModelSelectorButton" Click="ModelSelector_Click"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="6,2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock x:Name="ModelSelectorText" Text="{Binding SelectedModel}" FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" />
                                                            <TextBlock Text=" ▾" FontSize="10" Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Popup x:Name="ModelSelectorPopup" StaysOpen="False" Placement="Top"
                                                           PlacementTarget="{Binding ElementName=ModelSelectorButton}" AllowsTransparency="True">
                                                        <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1" CornerRadius="6" Padding="4" MaxHeight="300">
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                <ItemsControl x:Name="ModelSelectorList">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Content="{Binding}" FontSize="12"
                                                                                    Padding="12,6" HorizontalContentAlignment="Left"
                                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                                    Click="ModelSelectorItem_Click" Tag="{Binding}"
                                                                                    Loaded="ModelSelectorItem_Loaded" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                        </Border>
                                                    </Popup>
                                                </StackPanel>

                                                <!-- Send / Stop button (circular, accent color) -->
                                                <Button x:Name="SendStopButton" Grid.Column="4" Click="SendAiMessage" ToolTip="Send message (Enter)"
                                                        Width="32" Height="32" Cursor="Hand" Padding="0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="SendBorder" Background="{DynamicResource ButtonBackground}"
                                                                    CornerRadius="16" Width="32" Height="32">
                                                                <TextBlock x:Name="SendButtonIcon" Text="↑" FontSize="16" FontWeight="Bold"
                                                                           Foreground="{DynamicResource ButtonForeground}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="SendBorder" Property="Background" Value="{DynamicResource ButtonHoverBackground}" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="SendBorder" Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                            <!-- TextBox input area with placeholder (multi-line, auto-grow) -->
                                            <Grid Margin="12,8,12,0">
                                                <TextBox x:Name="AiChatInputTextBox"
                                                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="0,4" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap"
                                                         MaxHeight="120" MinHeight="24"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Background="Transparent" BorderThickness="0"
                                                         Foreground="{DynamicResource PrimaryForeground}"
                                                         CaretBrush="{DynamicResource InputCaret}"
                                                         PreviewKeyDown="OnAiChatPreviewKeyDown" />
                                                <TextBlock x:Name="AiChatPlaceholder" Text="How can I help you today?"
                                                           IsHitTestVisible="False" Padding="0,4" FontSize="13"
                                                           Foreground="{DynamicResource TertiaryForeground}" />
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </DockPanel>

                                <!-- Chat messages -->
                                <ScrollViewer x:Name="AiChatScrollViewer" VerticalScrollBarVisibility="Auto" Margin="8,0,8,0">
                                    <StackPanel x:Name="AiChatContainer">
                                        <ItemsControl x:Name="AiChatList" ItemsSource="{Binding ChatMessages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="4"
                                                            Background="{Binding Background}">
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Copy Message" Click="CopyAiMessage" />
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="10"
                                                                           Foreground="{DynamicResource SecondaryForeground}" Text="{Binding RoleLabel}" />
                                                                <TextBlock Grid.Column="1" FontSize="9" Foreground="{DynamicResource TertiaryForeground}"
                                                                           Text="{Binding Timestamp}" VerticalAlignment="Center" />
                                                            </Grid>
                                                            <!-- Image attachment (shown above text when present) -->
                                                            <Image Source="{Binding ImageSource}" MaxHeight="200" MaxWidth="400"
                                                                   HorizontalAlignment="Left" Margin="0,4,0,4"
                                                                   Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                                   ToolTip="Attached image" />
                                                            <TextBox Text="{Binding Content, Mode=OneWay}" FontSize="12"
                                                                     IsReadOnly="True" TextWrapping="Wrap"
                                                                     Background="Transparent" BorderThickness="0" Padding="0"
                                                                     Foreground="{DynamicResource PrimaryForeground}"
                                                                     Cursor="IBeam" IsTabStop="False" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Live streaming content blocks (OpenCode-style structured output) -->
                                        <ItemsControl x:Name="StreamingBlocksList" ItemsSource="{Binding StreamingBlocks}"
                                                      Visibility="{Binding IsStreamingBlocksVisible, Converter={StaticResource BoolToVisibility}}">
                                            <ItemsControl.Resources>
                                                <!-- TextContentBlock template -->
                                                <DataTemplate DataType="{x:Type models:TextContentBlock}">
                                                    <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="4"
                                                            Background="{Binding Background}">
                                                        <StackPanel>
                                                            <Grid>
                                                                <TextBlock FontWeight="SemiBold" FontSize="10"
                                                                           Foreground="{DynamicResource SecondaryForeground}" Text="{Binding RoleLabel}" />
                                                            </Grid>
                                                            <TextBox Text="{Binding Content, Mode=OneWay}" FontSize="12"
                                                                     IsReadOnly="True" TextWrapping="Wrap"
                                                                     Background="Transparent" BorderThickness="0" Padding="0"
                                                                     Foreground="{DynamicResource PrimaryForeground}"
                                                                     Cursor="IBeam" IsTabStop="False" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>

                                                <!-- ToolCallBlock template -->
                                                <DataTemplate DataType="{x:Type models:ToolCallBlock}">
                                                    <Border Padding="6,4" Margin="0,2,0,2" CornerRadius="4"
                                                            Background="{DynamicResource InputBackground}"
                                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                                                    <TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding ToolName}" FontWeight="SemiBold" FontFamily="Consolas" FontSize="11"
                                                                               Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding Status}" FontSize="10" Margin="8,0,0,0"
                                                                               Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1" Text="{Binding Timestamp}" FontSize="9"
                                                                           Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                                            </Grid>
                                                            <!-- Collapsible result (shown when completed) -->
                                                            <TextBox Text="{Binding Result, Mode=OneWay}" FontSize="10" FontFamily="Consolas"
                                                                     IsReadOnly="True" TextWrapping="Wrap" MaxHeight="200"
                                                                     Background="Transparent" BorderThickness="0" Padding="0,4,0,0"
                                                                     Foreground="{DynamicResource SecondaryForeground}"
                                                                     Visibility="{Binding Result, Converter={StaticResource NullToCollapsed}}"
                                                                     Cursor="IBeam" IsTabStop="False" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>

                                                <!-- ApprovalBlock template -->
                                                <DataTemplate DataType="{x:Type models:ApprovalBlock}">
                                                    <Border Padding="8,6" Margin="0,2,0,2" CornerRadius="4"
                                                            Background="{DynamicResource WarningBackground}"
                                                            BorderBrush="{DynamicResource WarningBorder}" BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock FontWeight="SemiBold" FontSize="11"
                                                                       Foreground="{DynamicResource WarningForeground}">
                                                                <Run Text="⚠ Approval: " /><Run Text="{Binding ToolName}" />
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding Arguments}" FontSize="10" FontFamily="Consolas"
                                                                       Foreground="{DynamicResource PrimaryForeground}" Margin="0,2,0,4" TextWrapping="Wrap" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="Allow" Padding="12,3" FontSize="10"
                                                                        Click="ApprovalBlock_Allow" Tag="{Binding}" Cursor="Hand" />
                                                                <Button Content="Deny" Padding="12,3" FontSize="10" Margin="8,0,0,0"
                                                                        Click="ApprovalBlock_Deny" Tag="{Binding}" Cursor="Hand"
                                                                        Foreground="OrangeRed" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.Resources>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <!-- Row 3: Status bar -->
        <Border Grid.Row="2" Background="{DynamicResource MenuBarBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBarProcess" Text="No process attached" FontSize="11"
                           Foreground="{DynamicResource SecondaryForeground}" />
                <TextBlock x:Name="StatusBarCenter" Grid.Column="1" HorizontalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TertiaryForeground}" />
                <TextBlock x:Name="StatusBarScan" Grid.Column="2" FontSize="11" Margin="12,0,0,0"
                           Foreground="{DynamicResource SecondaryForeground}"
                           ToolTip="Active scan status" />
                <TextBlock x:Name="StatusBarTokens" Grid.Column="3" FontSize="11" Margin="12,0,0,0"
                           Foreground="{DynamicResource TertiaryForeground}"
                           ToolTip="AI session token usage and cost" />
                <TextBlock x:Name="StatusBarWatchdog" Grid.Column="4" FontSize="11" Margin="12,0,0,0"
                           Foreground="OrangeRed" FontWeight="SemiBold"
                           ToolTip="Watchdog auto-rollback alert" />
                <TextBlock x:Name="StatusBarRight" Grid.Column="5" FontSize="11" Margin="12,0,0,0"
                           Foreground="{DynamicResource SecondaryForeground}" />
                <TextBlock x:Name="StatusBarDensity" Grid.Column="6" FontSize="11" Margin="12,0,0,0"
                           Foreground="{DynamicResource AccentForeground}" Cursor="Hand" Text="Balanced"
                           ToolTip="Click to cycle density preset (Clean → Balanced → Dense)"
                           MouseLeftButtonUp="CycleDensityPreset" />
            </Grid>
        </Border>
    </Grid>
</Window>
