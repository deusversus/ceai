<Window x:Class="CEAISuite.Desktop.McpManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCP Servers — CE AI Suite"
        Height="520" Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackground}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="4" CornerRadius="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource CaptionButton}" Click="CaptionMinimize_Click" ToolTip="Minimize">
                        <Path Stroke="{DynamicResource TitleBarForeground}" StrokeThickness="1" Data="M 0,5 H 10" Width="10" Height="10" Stretch="None" />
                    </Button>
                    <Button x:Name="CaptionMaximizeButton" Style="{StaticResource CaptionButton}" Click="CaptionMaximizeRestore_Click" ToolTip="Maximize">
                        <Path x:Name="MaximizeIcon" Stroke="{DynamicResource TitleBarForeground}"
                              StrokeThickness="1" Fill="Transparent" Data="M 0,0 H 10 V 10 H 0 Z" Width="10" Height="10" Stretch="Uniform" />
                    </Button>
                    <Button Style="{StaticResource CaptionCloseButton}" Click="CaptionClose_Click">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Data="M 0,0 L 10,10 M 10,0 L 0,10" Width="10" Height="10" Stretch="Uniform" />
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TitleBarForeground}" />
            </DockPanel>
        </Border>
    <Grid Grid.Row="1" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="MCP Servers" FontWeight="SemiBold" FontSize="16" />
            <TextBlock Text="Configure external tool servers using the Model Context Protocol"
                       Foreground="{DynamicResource SecondaryForeground}" FontSize="12" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Server list -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="+ Add" Click="AddServer_Click" Padding="10,4" Margin="0,0,6,0" />
                    <Button x:Name="RemoveBtn" Content="Remove" Click="RemoveServer_Click" Padding="10,4"
                            IsEnabled="False" />
                </StackPanel>
                <ListBox x:Name="ServerList" SelectionChanged="ServerList_SelectionChanged"
                         Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource BorderBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,4">
                                <TextBlock Text="{Binding StatusIcon}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding Command}" FontSize="10"
                                               Foreground="{DynamicResource TertiaryForeground}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="160" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Edit form -->
            <Border Grid.Column="1" Background="{DynamicResource PanelBackground}"
                    CornerRadius="4" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="EditPanel" Visibility="Collapsed">
                        <TextBlock Text="Server Name" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="ServerNameBox" FontSize="12" Padding="6,4" Margin="0,0,0,12" />

                        <TextBlock Text="Command" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                        <TextBlock Text="Executable to run (e.g., npx, python, path to binary)"
                                   Foreground="{DynamicResource TertiaryForeground}" FontSize="10" Margin="0,0,0,4" />
                        <TextBox x:Name="ServerCommandBox" FontFamily="Consolas" FontSize="12" Padding="6,4" Margin="0,0,0,12" />

                        <TextBlock Text="Arguments" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                        <TextBlock Text="Command-line arguments (e.g., -y @modelcontextprotocol/server-filesystem /path)"
                                   Foreground="{DynamicResource TertiaryForeground}" FontSize="10" Margin="0,0,0,4" />
                        <TextBox x:Name="ServerArgsBox" FontFamily="Consolas" FontSize="12" Padding="6,4" Margin="0,0,0,12" />

                        <TextBlock Text="Environment Variables" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                        <TextBlock Text="One per line: KEY=VALUE"
                                   Foreground="{DynamicResource TertiaryForeground}" FontSize="10" Margin="0,0,0,4" />
                        <TextBox x:Name="ServerEnvBox" FontFamily="Consolas" FontSize="12" Padding="6,4"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" />

                        <CheckBox x:Name="ServerEnabledCheck" Content="Enabled" FontSize="12" Margin="0,0,0,8" />
                        <CheckBox x:Name="ServerAutoConnectCheck" Content="Auto-connect on startup" FontSize="12" Margin="0,0,0,12" />

                        <Button x:Name="TestBtn" Content="Test Connection" Click="TestConnection_Click"
                                Padding="12,6" HorizontalAlignment="Left" />
                        <TextBlock x:Name="TestStatusText" FontSize="11" Margin="0,6,0,0"
                                   Foreground="{DynamicResource SecondaryForeground}" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Click="Save_Click" Padding="16,6" FontWeight="SemiBold" Margin="0,0,8,0" />
            <Button Content="Close" Click="Close_Click" Padding="16,6" />
        </StackPanel>
    </Grid>
    </Grid>
</Window>
