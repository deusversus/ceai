<UserControl x:Class="CEAISuite.Desktop.MemoryBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CEAISuite.Desktop.Controls"
             FontFamily="Consolas" FontSize="13"
             Background="{DynamicResource PanelBackground}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Address:" Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox x:Name="AddressBox" Width="180" FontFamily="Consolas"
                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" BorderBrush="{DynamicResource InputBorder}"
                     Text="{Binding GoToAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
            <Button Content="Go" Padding="12,4" Command="{Binding GoToCommand}"
                    Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" BorderBrush="{DynamicResource ButtonBackground}" />
            <TextBlock Text="  Bytes:" Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center" Margin="8,0,6,0" />
            <ComboBox Width="80" SelectedItem="{Binding ByteCount}"
                      ItemsSource="{Binding ByteCountOptions}"
                      Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" />
            <Button Content="&#x25C0; Prev" Padding="10,4" Margin="16,0,4,0" Command="{Binding PagePrevCommand}"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="Next &#x25B6;" Padding="10,4" Command="{Binding PageNextCommand}"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="&#x1F504; Refresh" Padding="10,4" Margin="16,0,0,0" Command="{Binding RefreshCommand}"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="Undo" Padding="10,4" Margin="8,0,2,0" Command="{Binding UndoCommand}"
                    IsEnabled="{Binding CanUndo}" ToolTip="Undo last byte edit (Ctrl+Z)"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="Redo" Padding="10,4" Margin="2,0,0,0" Command="{Binding RedoCommand}"
                    IsEnabled="{Binding CanRedo}" ToolTip="Redo last byte edit (Ctrl+Y)"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <TextBlock Text="  BPL:" Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center" Margin="8,0,6,0"
                       ToolTip="Bytes per line" />
            <ComboBox Width="55" SelectedItem="{Binding BytesPerLine}"
                      ItemsSource="{Binding BytesPerLineOptions}"
                      Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" />
            <CheckBox Content="Auto" Foreground="{DynamicResource PrimaryForeground}"
                      VerticalAlignment="Center" Margin="12,0,0,0"
                      IsChecked="{Binding AutoRefreshEnabled}" />
            <CheckBox Content="ASM" Foreground="{DynamicResource PrimaryForeground}"
                      VerticalAlignment="Center" Margin="8,0,0,0"
                      IsChecked="{Binding ShowDisassembly}" ToolTip="Show inline disassembly at cursor" />
            <Button Content="Bookmark" Padding="10,4" Margin="8,0,2,0" Command="{Binding AddBookmarkCommand}"
                    ToolTip="Add bookmark at cursor address"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="Spider" Padding="10,4" Margin="2,0,0,0" Command="{Binding SpiderCommand}"
                    ToolTip="Scan for pointers in current view"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
        </WrapPanel>

        <!-- Search bar -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Search:" Foreground="{DynamicResource PrimaryForeground}" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Width="200" FontFamily="Consolas"
                     Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}" BorderBrush="{DynamicResource InputBorder}"
                     Text="{Binding SearchPattern, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Hex bytes (90 90 90), wildcards (90 ?? CC), or ASCII text" />
            <Button Content="Find" Padding="10,4" Margin="4,0,2,0" Command="{Binding SearchCommand}"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="&#x25B2;" Padding="8,4" Margin="2,0,2,0" Command="{Binding PrevSearchHitCommand}" ToolTip="Previous match"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="&#x25BC;" Padding="8,4" Command="{Binding NextSearchHitCommand}" ToolTip="Next match"
                    Background="{DynamicResource ToolbarButtonBackground}" Foreground="{DynamicResource ToolbarButtonForeground}" BorderBrush="{DynamicResource BorderBrush}" />
            <TextBlock Foreground="{DynamicResource SecondaryForeground}" Text="{Binding SearchStatus}" VerticalAlignment="Center" Margin="8,0,0,0" />
        </WrapPanel>

        <!-- Phase 9E: Snapshot capture progress indicator -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3" Margin="0,0,0,2"
                     VerticalAlignment="Bottom"
                     Background="{DynamicResource InputBackground}" Foreground="#FF4CAF50">
            <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCapturingSnapshot}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>

        <!-- Main content: hex editor + side panels -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="240" MinWidth="150" />
            </Grid.ColumnDefinitions>

            <!-- Hex editor + inline disassembly -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <controls:HexEditorControl x:Name="HexEditor"
                            Source="{Binding MemoryBuffer}"
                            PreviousSource="{Binding PreviousBuffer}"
                            BaseAddress="{Binding BaseAddress}"
                            BytesPerLine="{Binding BytesPerLine}"
                            IsReadOnly="{Binding IsReadOnly}"
                            SelectionStart="{Binding SelectionStart, Mode=TwoWay}"
                            SelectionLength="{Binding SelectionLength, Mode=TwoWay}"
                            CursorOffset="{Binding CursorOffset, Mode=TwoWay}"
                            SearchHits="{Binding SearchHits}"
                            Bookmarks="{Binding BookmarkAddresses}">
                            <controls:HexEditorControl.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                             Background="{DynamicResource ContextMenuBackground}"
                                             Foreground="{DynamicResource ContextMenuForeground}"
                                             BorderBrush="{DynamicResource ContextMenuBorder}">
                                    <MenuItem Header="Copy Hex" Command="{Binding CopyHexCommand}" InputGestureText="Ctrl+C" />
                                    <MenuItem Header="Copy ASCII" Command="{Binding CopyAsciiCommand}" />
                                    <MenuItem Header="Copy Address" Command="{Binding CopyAddressCommand}" />
                                    <Separator />
                                    <MenuItem Header="Paste Hex" Command="{Binding PasteHexCommand}" InputGestureText="Ctrl+V" />
                                    <Separator />
                                    <MenuItem Header="Follow Pointer" Command="{Binding FollowPointerCommand}" />
                                    <MenuItem Header="Open in Disassembler" Command="{Binding DisassembleAtCursorCommand}" />
                                    <MenuItem Header="Dissect Structure" Command="{Binding DissectAtCursorCommand}" />
                                    <Separator />
                                    <MenuItem Header="Add Bookmark" Command="{Binding AddBookmarkCommand}" />
                                    <MenuItem Header="Remove Bookmark" Command="{Binding RemoveBookmarkCommand}" />
                                    <MenuItem Header="Add to Address Table" Command="{Binding AddToAddressTableCommand}" />
                                    <MenuItem Header="Capture Snapshot" Command="{Binding CaptureSnapshotCommand}" />
                                    <Separator />
                                    <MenuItem Header="Memory">
                                        <MenuItem Header="Allocate RWX Page (4KB)" Command="{Binding AllocateMemoryCommand}" />
                                        <MenuItem Header="Free Region" Command="{Binding FreeMemoryCommand}" />
                                        <MenuItem Header="Set RWX Protection" Command="{Binding ChangeProtectionCommand}" />
                                    </MenuItem>
                                    <MenuItem Header="Code Injection">
                                        <MenuItem Header="NOP Selection" Command="{Binding NopSelectionCommand}" />
                                        <MenuItem Header="Insert JMP Hook" Command="{Binding InsertJmpHookCommand}" />
                                    </MenuItem>
                                </ContextMenu>
                            </controls:HexEditorControl.ContextMenu>
                        </controls:HexEditorControl>
                    </ScrollViewer>
                </Border>

                <!-- Inline disassembly annotation -->
                <Border Grid.Row="1" Margin="0,2,0,0"
                        Visibility="{Binding ShowDisassembly, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                        Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        MaxHeight="120">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding DisassemblyAnnotation}" FontFamily="Consolas" FontSize="12"
                                   Foreground="{DynamicResource AccentForeground}" Padding="6,4" TextWrapping="NoWrap" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource SplitterBrush}" />

            <!-- Right side panel: Data Inspector + Bookmarks + Spider -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:DataInspectorPanel DataContext="{Binding DataInspector}" />

                <!-- Bookmarks -->
                <Expander Grid.Row="1" Header="Bookmarks" Foreground="{DynamicResource PrimaryForeground}"
                          IsExpanded="False" Margin="0,4,0,0">
                    <ListBox ItemsSource="{Binding Bookmarks}" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource PrimaryForeground}" MaxHeight="120"
                             Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Cursor="Hand" Foreground="{DynamicResource AccentForeground}"
                                           Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftDoubleClick"
                                                      Command="{Binding Tag.GoToBookmarkCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                      CommandParameter="{Binding}" />
                                    </TextBlock.InputBindings>
                                    <TextBlock.ContextMenu>
                                        <ContextMenu Background="{DynamicResource ContextMenuBackground}"
                                                     Foreground="{DynamicResource ContextMenuForeground}"
                                                     BorderBrush="{DynamicResource ContextMenuBorder}">
                                            <MenuItem Header="Go To"
                                                      Command="{Binding PlacementTarget.Tag.GoToBookmarkCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Copy Address"
                                                      Command="{Binding PlacementTarget.Tag.CopyBookmarkAddressCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Delete"
                                                      Command="{Binding PlacementTarget.Tag.DeleteBookmarkCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>

                <!-- Structure Spider (tree-based) -->
                <Expander Grid.Row="2" Header="Structure Spider" Foreground="{DynamicResource PrimaryForeground}"
                          IsExpanded="False" Margin="0,4,0,0">
                    <TreeView ItemsSource="{Binding SpiderNodes}" Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource PrimaryForeground}" MaxHeight="180">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Label}" Cursor="Hand" Foreground="{DynamicResource AccentForeground}">
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftDoubleClick"
                                                      Command="{Binding DataContext.FollowSpiderNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />
                                    </TextBlock.InputBindings>
                                </TextBlock>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Expander>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
            <TextBlock Foreground="{DynamicResource SecondaryForeground}" Text="{Binding StatusText}" Margin="0,0,16,0" />
            <TextBlock Foreground="{DynamicResource AccentForeground}" Text="{Binding ProtectionText}" />
        </StackPanel>
    </Grid>
</UserControl>
