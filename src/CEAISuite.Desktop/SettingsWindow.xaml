<Window x:Class="CEAISuite.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — CE AI Suite"
        Height="640" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
            <Setter Property="CaretBrush" Value="{DynamicResource InputCaret}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
            <Setter Property="CaretBrush" Value="{DynamicResource InputCaret}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}" />
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource TabControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TabForeground}" />
            <Setter Property="Background" Value="{DynamicResource TabBackground}" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabs">
            <TabItem Header="AI Provider">
                <Border Background="{DynamicResource PanelBackground}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel Margin="16">
                            <!-- Provider Selection — radio cards -->
                            <TextBlock Text="Provider" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Choose your AI backend"
                                       Foreground="{DynamicResource SecondaryForeground}" Margin="0,2,0,10" />

                            <UniformGrid Columns="4" x:Name="ProviderCards" Margin="0,0,0,4">
                                <RadioButton x:Name="ProviderOpenAI" GroupName="Provider" Tag="openai"
                                             Checked="ProviderCard_Checked" Style="{x:Null}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder" CornerRadius="6" Padding="10,10"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1.5">
                                                <StackPanel>
                                                    <TextBlock Text="OpenAI" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource PrimaryForeground}" />
                                                    <TextBlock Text="GPT-5, GPT-4, o3/o4" FontSize="11"
                                                               Foreground="{DynamicResource TertiaryForeground}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>

                                <RadioButton x:Name="ProviderAnthropic" GroupName="Provider" Tag="anthropic"
                                             Checked="ProviderCard_Checked" Style="{x:Null}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder" CornerRadius="6" Padding="10,10"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1.5">
                                                <StackPanel>
                                                    <TextBlock Text="Anthropic" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource PrimaryForeground}" />
                                                    <TextBlock Text="Claude Opus, Sonnet, Haiku" FontSize="11"
                                                               Foreground="{DynamicResource TertiaryForeground}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>

                                <RadioButton x:Name="ProviderCopilot" GroupName="Provider" Tag="copilot"
                                             Checked="ProviderCard_Checked" Style="{x:Null}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder" CornerRadius="6" Padding="10,10"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1.5">
                                                <StackPanel>
                                                    <TextBlock Text="GitHub Copilot" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource PrimaryForeground}" />
                                                    <TextBlock Text="Uses your Copilot subscription" FontSize="11"
                                                               Foreground="{DynamicResource TertiaryForeground}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>

                                <RadioButton x:Name="ProviderCompatible" GroupName="Provider" Tag="openai-compatible"
                                             Checked="ProviderCard_Checked" Style="{x:Null}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder" CornerRadius="6" Padding="10,10"
                                                    Margin="0,0,0,0" Cursor="Hand"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1.5">
                                                <StackPanel>
                                                    <TextBlock Text="Compatible" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource PrimaryForeground}" />
                                                    <TextBlock Text="Ollama, LM Studio, etc." FontSize="11"
                                                               Foreground="{DynamicResource TertiaryForeground}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </UniformGrid>

                            <!-- Custom endpoint (only for compatible) -->
                            <StackPanel x:Name="CustomEndpointPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                <TextBlock Text="Endpoint URL" FontSize="12"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4" />
                                <TextBox x:Name="EndpointBox" FontFamily="Consolas" FontSize="12" Padding="8,6"
                                         Text="http://localhost:11434/v1/" />
                            </StackPanel>

                            <Separator Margin="0,14,0,14" />

                            <!-- Model Selection — card list -->
                            <TextBlock Text="Model" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock x:Name="ModelSubtitle" Text="Select the model for the AI operator"
                                       Foreground="{DynamicResource SecondaryForeground}" Margin="0,2,0,8" />

                            <ListBox x:Name="ModelList" BorderThickness="0" Padding="0"
                                     Background="Transparent"
                                     SelectionChanged="ModelList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" CornerRadius="5" Padding="10,7" Margin="0,0,0,4"
                                                            Background="{DynamicResource InputBackground}"
                                                            BorderBrush="{DynamicResource InputBorder}" BorderThickness="1">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <!-- Custom model override -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="or type:" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TertiaryForeground}" Margin="0,0,8,0" />
                                <TextBox x:Name="CustomModelBox" Grid.Column="1" FontFamily="Consolas" FontSize="12"
                                         Padding="6,4" TextChanged="CustomModelBox_TextChanged" />
                            </Grid>

                            <Separator Margin="0,14,0,14" />

                            <!-- API Key (for OpenAI, Anthropic, Compatible) -->
                            <StackPanel x:Name="ApiKeyPanel">
                                <TextBlock Text="API Key" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock x:Name="ApiKeySubtitle" Text="Get yours at platform.openai.com"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="0,2,0,8" TextWrapping="Wrap" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="ApiKeyBox" FontFamily="Consolas" FontSize="13"
                                             Padding="8,6" VerticalContentAlignment="Center" />
                                <Button Grid.Column="1" Content="Show" Margin="8,0,0,0" Padding="10,6"
                                        Click="ToggleApiKeyVisibility" x:Name="ShowKeyBtn" />
                            </Grid>
                            <TextBox x:Name="ApiKeyTextBox" FontFamily="Consolas" FontSize="13"
                                     Padding="8,6" Margin="0,4,0,0" Visibility="Collapsed" />

                            <TextBlock x:Name="ApiKeyStatus" Margin="0,6,0,0"
                                       Foreground="{DynamicResource SecondaryForeground}" FontSize="12" />
                            </StackPanel>

                            <!-- GitHub Auth (for Copilot provider) -->
                            <StackPanel x:Name="GitHubTokenPanel" Visibility="Collapsed">
                                <TextBlock Text="GitHub Authentication" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="Sign in with your GitHub account to use Copilot models"
                                           Foreground="{DynamicResource SecondaryForeground}" Margin="0,2,0,8" TextWrapping="Wrap" />

                                <Button x:Name="GitHubSignInBtn" Content="🔗  Sign in with GitHub"
                                        Click="GitHubSignIn_Click" Padding="16,10" FontSize="14" FontWeight="SemiBold"
                                        HorizontalAlignment="Left" Cursor="Hand" />

                                <StackPanel x:Name="DeviceFlowPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Enter this code on GitHub:" FontSize="13"
                                               Foreground="{DynamicResource SecondaryForeground}" />
                                    <TextBlock x:Name="DeviceCodeText" FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                                               Margin="0,6,0,6" Cursor="Hand" MouseLeftButtonUp="CopyDeviceCode_Click" />
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TertiaryForeground}" Margin="0,0,0,8">
                                        <Run Text="Click the code to copy  •  " />
                                        <Run x:Name="DeviceFlowStatusText" Text="Waiting for authorization…" />
                                    </TextBlock>
                                    <ProgressBar x:Name="DeviceFlowProgress" IsIndeterminate="True" Height="3"
                                                 Margin="0,0,0,4" />
                                </StackPanel>

                                <TextBlock x:Name="GitHubTokenStatus" Margin="0,8,0,0"
                                           Foreground="{DynamicResource SecondaryForeground}" FontSize="12" />

                                <!-- Copilot Usage / Quota -->
                                <StackPanel x:Name="CopilotUsagePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Separator Margin="0,0,0,10" />
                                    <TextBlock Text="Copilot Usage" FontWeight="SemiBold" FontSize="13" />

                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Plan:" FontSize="12" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,6,0" />
                                        <TextBlock x:Name="UsagePlanText" Text="—" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>

                                    <TextBlock Text="Premium Interactions" FontSize="12" Margin="0,8,0,2"
                                               Foreground="{DynamicResource SecondaryForeground}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar x:Name="PremiumProgressBar" Height="12" Minimum="0" Maximum="100" Value="0"
                                                     Background="{DynamicResource InputBackground}"
                                                     Foreground="{DynamicResource SelectionHighlight}" />
                                        <TextBlock x:Name="PremiumUsageText" Grid.Column="1" FontSize="11" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}" />
                                    </Grid>

                                    <StackPanel x:Name="ChatQuotaPanel" Visibility="Collapsed" Margin="0,6,0,0">
                                        <TextBlock Text="Chat" FontSize="12" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,2" />
                                        <TextBlock x:Name="ChatQuotaText" FontSize="11" Foreground="{DynamicResource TertiaryForeground}" />
                                    </StackPanel>

                                    <StackPanel x:Name="CompletionsQuotaPanel" Visibility="Collapsed" Margin="0,6,0,0">
                                        <TextBlock Text="Completions" FontSize="12" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,2" />
                                        <TextBlock x:Name="CompletionsQuotaText" FontSize="11" Foreground="{DynamicResource TertiaryForeground}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Resets:" FontSize="11" Foreground="{DynamicResource TertiaryForeground}" Margin="0,0,6,0" />
                                        <TextBlock x:Name="UsageResetText" Text="—" FontSize="11" Foreground="{DynamicResource TertiaryForeground}" />
                                    </StackPanel>

                                    <Button x:Name="RefreshUsageBtn" Content="↻ Refresh Usage" Margin="0,8,0,0"
                                            Padding="10,5" FontSize="11" HorizontalAlignment="Left"
                                            Click="RefreshUsage_Click" />
                                    <TextBlock x:Name="UsageErrorText" Margin="0,4,0,0" FontSize="11"
                                               Foreground="{DynamicResource ErrorForeground}" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Hidden fallback for manual token entry -->
                                <Expander Header="Advanced: paste token manually" Margin="0,10,0,0"
                                          FontSize="11" Foreground="{DynamicResource TertiaryForeground}">
                                    <StackPanel Margin="0,6,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="GitHubTokenBox" FontFamily="Consolas" FontSize="13"
                                                         Padding="8,6" VerticalContentAlignment="Center" />
                                            <Button Grid.Column="1" Content="Show" Margin="8,0,0,0" Padding="10,6"
                                                    Click="ToggleGitHubTokenVisibility" x:Name="ShowGitHubTokenBtn" />
                                        </Grid>
                                        <TextBox x:Name="GitHubTokenTextBox" FontFamily="Consolas" FontSize="13"
                                                 Padding="8,6" Margin="0,4,0,0" Visibility="Collapsed" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>

                            <TextBlock Text="Provider and model changes take effect on next message."
                                       Foreground="{DynamicResource TertiaryForeground}" Margin="0,14,0,0" FontSize="11" FontStyle="Italic" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="General">
                <Border Background="{DynamicResource PanelBackground}">
                    <StackPanel Margin="16">
                        <TextBlock Text="Address Table Refresh Interval" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="How often to refresh values in the address table (milliseconds)"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,4,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RefreshIntervalBox" Width="80" FontFamily="Consolas"
                                     Padding="8,6" Text="500" />
                            <Slider Grid.Column="1" x:Name="RefreshSlider" Minimum="100" Maximum="2000"
                                    Value="500" TickFrequency="100" IsSnapToTickEnabled="True"
                                    Margin="12,0" VerticalAlignment="Center"
                                    ValueChanged="RefreshSlider_ValueChanged" />
                            <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center" />
                        </Grid>

                        <Separator Margin="0,20,0,20" />

                        <CheckBox x:Name="ShowUnresolvedCheck" Content="Show unresolved pointers as '??' (CE-style)"
                                  IsChecked="True" FontSize="13" />

                        <CheckBox x:Name="StreamingCheck" Content="Stream AI responses (real-time token display)"
                                  IsChecked="True" FontSize="13" Margin="0,10,0,0" />

                        <CheckBox x:Name="AutoOpenMemoryBrowserCheck" Content="Auto-open Memory Browser on process attach"
                                  IsChecked="True" FontSize="13" Margin="0,10,0,0" />

                        <Separator Margin="0,20,0,20" />

                        <TextBlock Text="Rate Limiting" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="Minimum time between AI requests (prevents abuse detection)"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,4,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RateLimitBox" Width="60" FontFamily="Consolas"
                                     Padding="8,6" Text="0" />
                            <Slider Grid.Column="1" x:Name="RateLimitSlider" Minimum="0" Maximum="60"
                                    Value="0" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Margin="12,0" VerticalAlignment="Center"
                                    ValueChanged="RateLimitSlider_ValueChanged" />
                            <TextBlock Grid.Column="2" Text="sec" VerticalAlignment="Center" />
                        </Grid>

                        <CheckBox x:Name="RateLimitWaitCheck"
                                  Content="Wait for cooldown instead of rejecting"
                                  IsChecked="True" FontSize="13" Margin="0,10,0,0" />

                        <TextBlock Text="Set to 0 to disable rate limiting."
                                   Foreground="{DynamicResource TertiaryForeground}" Margin="0,6,0,0" FontSize="11" FontStyle="Italic" />
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Performance">
                <Border Background="{DynamicResource PanelBackground}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel Margin="16">
                            <TextBlock Text="Token Profile" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Controls how much data the AI sends and receives per request"
                                       Foreground="{DynamicResource SecondaryForeground}" Margin="0,2,0,10" />

                            <!-- Profile selector cards -->
                            <UniformGrid Columns="3" Margin="0,0,0,4">
                                <RadioButton x:Name="ProfileSaving" GroupName="TokenProfile" Tag="saving"
                                             Checked="ProfileCard_Checked" Style="{x:Null}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder" CornerRadius="6" Padding="10,10"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1.5">
                                                <StackPanel>
                                                    <TextBlock Text="💰 Token Saving" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource PrimaryForeground}" />
                                                    <TextBlock Text="Minimize cost per request" FontSize="10"
                                                               Foreground="{DynamicResource TertiaryForeground}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>

                                <RadioButton x:Name="ProfileBalanced" GroupName="TokenProfile" Tag="balanced"
                                             Checked="ProfileCard_Checked" Style="{x:Null}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder" CornerRadius="6" Padding="10,10"
                                                    Margin="0,0,6,0" Cursor="Hand"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1.5">
                                                <StackPanel>
                                                    <TextBlock Text="⚖️ Balanced" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource PrimaryForeground}" />
                                                    <TextBlock Text="Good mix of cost and detail" FontSize="10"
                                                               Foreground="{DynamicResource TertiaryForeground}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>

                                <RadioButton x:Name="ProfilePerformance" GroupName="TokenProfile" Tag="performance"
                                             Checked="ProfileCard_Checked" Style="{x:Null}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="CardBorder" CornerRadius="6" Padding="10,10"
                                                    Margin="0,0,0,0" Cursor="Hand"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}" BorderThickness="1.5">
                                                <StackPanel>
                                                    <TextBlock Text="🚀 Performance" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource PrimaryForeground}" />
                                                    <TextBlock Text="Maximum detail, higher cost" FontSize="10"
                                                               Foreground="{DynamicResource TertiaryForeground}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource SelectionHighlight}" />
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemSelectedBackground}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ListItemHoverBackground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </UniformGrid>

                            <!-- Profile description -->
                            <TextBlock x:Name="ProfileDescription" FontSize="11" FontStyle="Italic"
                                       Foreground="{DynamicResource TertiaryForeground}" Margin="0,6,0,0"
                                       TextWrapping="Wrap" />

                            <Separator Margin="0,16,0,16" />

                            <!-- Advanced overrides (collapsible) -->
                            <Expander Header="Advanced Overrides" FontWeight="SemiBold" FontSize="13"
                                      Foreground="{DynamicResource PrimaryForeground}" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Override individual limits. Leave blank to use profile defaults."
                                               Foreground="{DynamicResource TertiaryForeground}" FontSize="11"
                                               FontWeight="Normal" Margin="0,0,0,12" />

                                    <!-- LLM / Pipeline -->
                                    <TextBlock Text="LLM &amp; Pipeline" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max output tokens" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxOutputTokens" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:2048  B:4096  P:8192" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max images per turn" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxImagesPerTurn" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:3  B:5  P:10" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max approval rounds" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxApprovalRounds" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:5  B:10  P:15" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max replay messages" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxReplayMessages" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:20  B:40  P:80" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max tool result chars" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxToolResultChars" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:2000  B:5000  P:10000" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Separator Margin="0,8,0,12" />

                                    <!-- Tool Output -->
                                    <TextBlock Text="Tool Output" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max stack frames" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxStackFrames" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:8  B:16  P:32" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max memory browse bytes" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxBrowseMemoryBytes" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:512  B:2048  P:4096" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max hit log entries" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxHitLogEntries" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:10  B:25  P:50" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max search results" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxSearchResults" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:20  B:50  P:100" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max chat search results" VerticalAlignment="Center" FontWeight="Normal" FontSize="12" />
                                        <TextBox x:Name="LimitMaxChatSearchResults" Grid.Column="1" FontFamily="Consolas" Padding="4,3" />
                                        <TextBlock Grid.Column="2" Text="S:10  B:20  P:50" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TertiaryForeground}" VerticalAlignment="Center" />
                                    </Grid>

                                    <Separator Margin="0,8,0,12" />

                                    <!-- Toggles -->
                                    <TextBlock Text="Behavior" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />

                                    <CheckBox x:Name="LimitFilterRegisters" Content="Filter registers to essentials only (saves ~60% per breakpoint hit)"
                                              FontSize="12" FontWeight="Normal" Margin="0,0,0,6" IsThreeState="True" />

                                    <CheckBox x:Name="LimitDereferenceHookRegisters" Content="Auto-dereference hook registers (extra memory reads per hit)"
                                              FontSize="12" FontWeight="Normal" Margin="0,0,0,6" IsThreeState="True" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="Appearance">
                <Border Background="{DynamicResource PanelBackground}">
                    <StackPanel Margin="16">
                        <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="Choose your preferred color scheme"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,4,0,12" />

                        <RadioButton x:Name="ThemeSystem" Content="System default" GroupName="Theme"
                                     Foreground="{DynamicResource PrimaryForeground}" FontSize="13" Margin="0,0,0,8"
                                     Checked="ThemeRadio_Checked" />
                        <TextBlock Text="Follows your Windows appearance setting"
                                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="20,0,0,12" />

                        <RadioButton x:Name="ThemeDark" Content="Dark" GroupName="Theme"
                                     Foreground="{DynamicResource PrimaryForeground}" FontSize="13" Margin="0,0,0,8"
                                     Checked="ThemeRadio_Checked" />
                        <TextBlock Text="Dark background with light text — easy on the eyes"
                                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="20,0,0,12" />

                        <RadioButton x:Name="ThemeLight" Content="Light" GroupName="Theme"
                                     Foreground="{DynamicResource PrimaryForeground}" FontSize="13" Margin="0,0,0,8"
                                     Checked="ThemeRadio_Checked" />
                        <TextBlock Text="Light background with dark text — classic look"
                                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="20,0,0,12" />

                        <TextBlock Text="Theme changes apply immediately."
                                   Foreground="{DynamicResource WarningForeground}" Margin="0,16,0,0" FontStyle="Italic" />

                        <Separator Margin="0,20,0,16" />

                        <TextBlock Text="Information Density" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="Controls default panel visibility and UI complexity"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,4,0,12" />

                        <RadioButton x:Name="DensityClean" Content="Clean" GroupName="Density"
                                     Foreground="{DynamicResource PrimaryForeground}" FontSize="13" Margin="0,0,0,4" />
                        <TextBlock Text="Minimal — sidebar hidden, bottom panel collapsed, essentials only"
                                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="20,0,0,12" />

                        <RadioButton x:Name="DensityBalanced" Content="Balanced" GroupName="Density"
                                     Foreground="{DynamicResource PrimaryForeground}" FontSize="13" Margin="0,0,0,4" />
                        <TextBlock Text="Default — process sidebar visible, output tab open, full toolbar"
                                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="20,0,0,12" />

                        <RadioButton x:Name="DensityDense" Content="Dense" GroupName="Density"
                                     Foreground="{DynamicResource PrimaryForeground}" FontSize="13" Margin="0,0,0,4" />
                        <TextBlock Text="Power user — all panels expanded, extra status bar details"
                                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="20,0,0,12" />

                        <!-- Layout Reset -->
                        <TextBlock Text="Layout" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="Reset panel positions and sizes to default."
                                   Foreground="{DynamicResource SecondaryForeground}" FontSize="11" Margin="0,4,0,8" />
                        <Button Content="Reset Layout" Padding="12,6" HorizontalAlignment="Left"
                                Click="ResetLayoutFromSettings" ToolTip="Restores default panel layout on next restart" />
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Padding="20,8" Click="SaveSettings" IsDefault="True"
                    FontWeight="SemiBold" />
            <Button Content="Cancel" Padding="20,8" Margin="8,0,0,0" Click="CancelSettings"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
