<Window x:Class="CEAISuite.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — CE AI Suite"
        Height="480" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabs">
            <!-- API Keys Tab -->
            <TabItem Header="🔑 API Keys">
                <StackPanel Margin="16">
                    <TextBlock Text="OpenAI API Key" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Used for the integrated AI operator. Get yours at platform.openai.com" 
                               Foreground="#666" Margin="0,4,0,8" TextWrapping="Wrap" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ApiKeyBox" FontFamily="Consolas" FontSize="13"
                                     Padding="8,6" VerticalContentAlignment="Center" />
                        <Button Grid.Column="1" Content="👁 Show" Margin="8,0,0,0" Padding="10,6"
                                Click="ToggleApiKeyVisibility" x:Name="ShowKeyBtn" />
                    </Grid>
                    <TextBox x:Name="ApiKeyTextBox" FontFamily="Consolas" FontSize="13"
                             Padding="8,6" Margin="0,4,0,0" Visibility="Collapsed" />
                    
                    <TextBlock Text="Status:" FontWeight="SemiBold" Margin="0,16,0,4" />
                    <TextBlock x:Name="ApiKeyStatus" Foreground="#888" />
                    
                    <Separator Margin="0,20,0,20" />
                    
                    <TextBlock Text="Model" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Which OpenAI model to use for the AI operator" 
                               Foreground="#666" Margin="0,4,0,8" />
                    <ComboBox x:Name="ModelCombo" IsEditable="True" FontFamily="Consolas" Padding="8,6">
                        <ComboBoxItem Content="gpt-5.4" />
                        <ComboBoxItem Content="gpt-4.1" />
                        <ComboBoxItem Content="gpt-4o" />
                        <ComboBoxItem Content="gpt-4o-mini" />
                        <ComboBoxItem Content="o3" />
                        <ComboBoxItem Content="o4-mini" />
                    </ComboBox>
                    
                    <TextBlock Text="💡 Changes to API key or model require app restart to take effect."
                               Foreground="#B8860B" Margin="0,16,0,0" FontStyle="Italic" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>
            
            <!-- General Tab -->
            <TabItem Header="⚙ General">
                <StackPanel Margin="16">
                    <TextBlock Text="Address Table Refresh Interval" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="How often to refresh values in the address table (milliseconds)" 
                               Foreground="#666" Margin="0,4,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RefreshIntervalBox" Width="80" FontFamily="Consolas"
                                 Padding="8,6" Text="500" />
                        <Slider Grid.Column="1" x:Name="RefreshSlider" Minimum="100" Maximum="2000" 
                                Value="500" TickFrequency="100" IsSnapToTickEnabled="True"
                                Margin="12,0" VerticalAlignment="Center"
                                ValueChanged="RefreshSlider_ValueChanged" />
                        <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center" />
                    </Grid>
                    
                    <Separator Margin="0,20,0,20" />
                    
                    <CheckBox x:Name="ShowUnresolvedCheck" Content="Show unresolved pointers as '??' (CE-style)" 
                              IsChecked="True" FontSize="13" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Padding="20,8" Click="SaveSettings" IsDefault="True" 
                    FontWeight="SemiBold" />
            <Button Content="Cancel" Padding="20,8" Margin="8,0,0,0" Click="CancelSettings" 
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
