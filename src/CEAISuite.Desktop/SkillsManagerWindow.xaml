<Window x:Class="CEAISuite.Desktop.SkillsManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skills Manager — CE AI Suite"
        Height="550" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackground}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="4" CornerRadius="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>
    <!-- All default styles inherited from Themes/SharedStyles.xaml (merged at App level) -->
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource CaptionButton}" Click="CaptionMinimize_Click" ToolTip="Minimize">
                        <Path Stroke="{DynamicResource TitleBarForeground}" StrokeThickness="1" Data="M 0,5 H 10" Width="10" Height="10" Stretch="None" />
                    </Button>
                    <Button x:Name="CaptionMaximizeButton" Style="{StaticResource CaptionButton}" Click="CaptionMaximizeRestore_Click" ToolTip="Maximize">
                        <Path x:Name="MaximizeIcon" Stroke="{DynamicResource TitleBarForeground}"
                              StrokeThickness="1" Fill="Transparent" Data="M 0,0 H 10 V 10 H 0 Z" Width="10" Height="10" Stretch="Uniform" />
                    </Button>
                    <Button Style="{StaticResource CaptionCloseButton}" Click="CaptionClose_Click">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Data="M 0,0 L 10,10 M 10,0 L 0,10" Width="10" Height="10" Stretch="Uniform" />
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TitleBarForeground}" />
            </DockPanel>
        </Border>
    <Grid Grid.Row="1" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content: skill list + details -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: skill list -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top" Text="Skills" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                <ListBox x:Name="SkillList" SelectionChanged="SkillList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,4">
                                <TextBlock>
                                    <Run Text="{Binding Icon, Mode=OneWay}" />
                                    <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                                </TextBlock>
                                <TextBlock Text="{Binding Description, Mode=OneWay}"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           FontSize="11" TextTrimming="CharacterEllipsis"
                                           MaxWidth="220" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Right panel: skill details -->
            <Border Grid.Column="1" Background="{DynamicResource PanelBackground}"
                    CornerRadius="4" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                        <TextBlock x:Name="DetailName" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailType" FontSize="12"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,12" />

                        <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailDescription" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:" FontWeight="SemiBold"
                                       Margin="0,0,12,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailVersion"
                                       Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Author:" FontWeight="SemiBold"
                                       Margin="0,0,12,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailAuthor"
                                       Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Path:" FontWeight="SemiBold"
                                       Margin="0,0,12,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailPath" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TertiaryForeground}" FontSize="11"
                                       Margin="0,0,0,4" />
                        </Grid>

                        <TextBlock Text="Tags" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock x:Name="DetailTags" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,4" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="New Skill" Click="NewSkill_Click" Margin="0,0,8,0" Padding="14,6" />
            <Button x:Name="EditButton" Content="Edit" Click="EditSkill_Click" IsEnabled="False"
                    Margin="0,0,8,0" Padding="14,6" />
            <Button x:Name="DeleteButton" Content="Delete" Click="DeleteSkill_Click" IsEnabled="False"
                    Margin="0,0,8,0" Padding="14,6" />
            <Button Content="Open in Explorer" Click="OpenInExplorer_Click" Margin="0,0,8,0" Padding="14,6" />
            <Button Content="Close" Click="Close_Click" Padding="14,6" />
        </StackPanel>
    </Grid>
    </Grid>
</Window>
