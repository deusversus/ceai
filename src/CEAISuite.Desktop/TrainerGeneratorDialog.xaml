<Window x:Class="CEAISuite.Desktop.TrainerGeneratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate Trainer" Width="700" Height="550"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: Process name + title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Process:" VerticalAlignment="Center" Width="80" />
                <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}" Width="200" />
                <TextBlock Text="Title:" VerticalAlignment="Center" Margin="16,0,0,0" Width="40" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="200" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Refresh (ms):" VerticalAlignment="Center" Width="80" />
                <Slider Value="{Binding RefreshIntervalMs}" Minimum="50" Maximum="1000"
                        TickFrequency="50" IsSnapToTickEnabled="True" Width="200"
                        ToolTip="How often the trainer re-writes values (lower = more aggressive)" />
                <TextBlock Text="{Binding RefreshIntervalMs, StringFormat={}{0} ms}" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Middle: Entry checklist -->
        <DockPanel Grid.Row="1">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Entries:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="Select All" Command="{Binding SelectAllCommand}" Margin="8,0,0,0" Padding="8,2" />
                <Button Content="Select None" Command="{Binding SelectNoneCommand}" Margin="4,0,0,0" Padding="8,2" />
            </StackPanel>
            <ListView ItemsSource="{Binding Entries}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="30">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Label" DisplayMemberBinding="{Binding Label}" Width="180" />
                        <GridViewColumn Header="Address" DisplayMemberBinding="{Binding Address}" Width="140" />
                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding DataType}" Width="70" />
                        <GridViewColumn Header="Value" DisplayMemberBinding="{Binding Value}" Width="80" />
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!-- Preview area (collapsible) -->
        <TextBox Grid.Row="2" Text="{Binding PreviewSource, Mode=OneWay}" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="11" MaxHeight="200"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Margin="0,8,0,0"
                 Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Bottom: Buttons + status -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryForeground}" FontSize="11" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Preview Source" Command="{Binding GeneratePreviewCommand}" Padding="12,4" Margin="0,0,4,0" />
                <Button Content="Save .cs…" Click="SaveTrainerFile" Padding="12,4" Margin="0,0,4,0" />
                <Button Content="Build .exe…" Click="BuildTrainerExe" Padding="12,4" Margin="0,0,4,0"
                        ToolTip="Compile trainer to standalone executable via Roslyn" />
                <Button Content="Close" Click="CloseDialog" Padding="12,4" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
