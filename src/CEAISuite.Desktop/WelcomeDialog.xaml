<Window x:Class="CEAISuite.Desktop.WelcomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to CE AI Suite"
        Icon="icon.ico"
        Height="480" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarBackground}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource CaptionCloseButton}" Click="CaptionClose_Click">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" Data="M 0,0 L 10,10 M 10,0 L 0,10" Width="10" Height="10" Stretch="Uniform" />
                </Button>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TitleBarForeground}" />
            </DockPanel>
        </Border>
    <Grid Grid.Row="1" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Heading (updates per page) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="PageTitle" Text="Let's get you set up"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}" />
            <TextBlock x:Name="PageSubtitle" Text="You can change these later in Settings."
                       FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource SecondaryForeground}" />
        </StackPanel>

        <!-- ═══════════════════════════════════════════ -->
        <!-- Page 0: Settings (API Key, Theme, Density) -->
        <!-- ═══════════════════════════════════════════ -->
        <ScrollViewer x:Name="Page0" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Section 1: AI Provider -->
                <TextBlock Text="AI Provider" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource PrimaryForeground}" />
                <TextBlock Text="Choose your AI backend"
                           FontSize="12" Margin="0,2,0,10"
                           Foreground="{DynamicResource SecondaryForeground}" />
                <UniformGrid Columns="3" Rows="2" Margin="0,0,0,4">
                    <RadioButton x:Name="ProviderOpenAI" GroupName="Provider" Tag="openai"
                                 IsChecked="True" Checked="Provider_Checked"
                                 Style="{StaticResource ProviderCardRadioButton}" Margin="0,0,4,0">
                        <TextBlock Text="OpenAI" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                    </RadioButton>
                    <RadioButton x:Name="ProviderAnthropic" GroupName="Provider" Tag="anthropic"
                                 Checked="Provider_Checked"
                                 Style="{StaticResource ProviderCardRadioButton}" Margin="0,0,4,0">
                        <TextBlock Text="Anthropic" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                    </RadioButton>
                    <RadioButton x:Name="ProviderGemini" GroupName="Provider" Tag="gemini"
                                 Checked="Provider_Checked"
                                 Style="{StaticResource ProviderCardRadioButton}" Margin="0,0,4,0">
                        <TextBlock Text="Gemini" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                    </RadioButton>
                    <RadioButton x:Name="ProviderCopilot" GroupName="Provider" Tag="copilot"
                                 Checked="Provider_Checked"
                                 Style="{StaticResource ProviderCardRadioButton}" Margin="0,0,4,0">
                        <TextBlock Text="Copilot" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                    </RadioButton>
                    <RadioButton x:Name="ProviderOpenRouter" GroupName="Provider" Tag="openrouter"
                                 Checked="Provider_Checked"
                                 Style="{StaticResource ProviderCardRadioButton}" Margin="0,0,4,0">
                        <TextBlock Text="OpenRouter" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                    </RadioButton>
                    <RadioButton x:Name="ProviderCompatible" GroupName="Provider" Tag="openai-compatible"
                                 Checked="Provider_Checked"
                                 Style="{StaticResource ProviderCardRadioButton}">
                        <TextBlock Text="Compatible" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryForeground}" />
                    </RadioButton>
                </UniformGrid>

                <Separator Margin="0,12,0,12" />

                <!-- Section 2: API Key (hidden for Copilot) -->
                <StackPanel x:Name="ApiKeySection">
                    <TextBlock Text="API Key" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource PrimaryForeground}" />
                    <TextBlock x:Name="ApiKeySubtitle" Text="Get yours at platform.openai.com"
                               FontSize="12" Margin="0,2,0,8"
                               Foreground="{DynamicResource SecondaryForeground}" />
                    <PasswordBox x:Name="ApiKeyBox" FontFamily="Consolas" FontSize="13"
                                 Padding="8,6" />
                </StackPanel>

                <!-- Copilot note (shown only for Copilot) -->
                <TextBlock x:Name="CopilotNote" Visibility="Collapsed"
                           Text="GitHub Copilot uses device-flow authentication. Configure it in Settings after setup."
                           FontSize="12" TextWrapping="Wrap" FontStyle="Italic"
                           Foreground="{DynamicResource SecondaryForeground}" />

                <Separator Margin="0,16,0,16" />

                <!-- Section 2: Theme -->
                <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource PrimaryForeground}" />
                <TextBlock Text="Choose your preferred appearance"
                           FontSize="12" Margin="0,2,0,8"
                           Foreground="{DynamicResource SecondaryForeground}" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="ThemeDark" Content="Dark" GroupName="Theme"
                                 IsChecked="True" Margin="0,0,16,0"
                                 Foreground="{DynamicResource PrimaryForeground}"
                                 Checked="ThemeRadio_Checked" />
                    <RadioButton x:Name="ThemeLight" Content="Light" GroupName="Theme"
                                 Foreground="{DynamicResource PrimaryForeground}"
                                 Checked="ThemeRadio_Checked" />
                </StackPanel>

                <Separator Margin="0,16,0,16" />

                <!-- Section 3: Density -->
                <TextBlock Text="UI Density" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource PrimaryForeground}" />
                <TextBlock Text="Controls default panel visibility"
                           FontSize="12" Margin="0,2,0,8"
                           Foreground="{DynamicResource SecondaryForeground}" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="DensityClean" Content="Clean" GroupName="Density"
                                 Margin="0,0,16,0"
                                 Foreground="{DynamicResource PrimaryForeground}" />
                    <RadioButton x:Name="DensityBalanced" Content="Balanced" GroupName="Density"
                                 IsChecked="True" Margin="0,0,16,0"
                                 Foreground="{DynamicResource PrimaryForeground}" />
                    <RadioButton x:Name="DensityDense" Content="Dense" GroupName="Density"
                                 Foreground="{DynamicResource PrimaryForeground}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════ -->
        <!-- Page 1: Getting Started Overview   -->
        <!-- ═══════════════════════════════════ -->
        <StackPanel x:Name="Page1" Grid.Row="1" Visibility="Collapsed">
            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,16"
                       Foreground="{DynamicResource PrimaryForeground}">
                CE AI Suite is an AI-powered memory analysis tool. Here's a quick overview of the core workflow:
            </TextBlock>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">1. Attach to a Process</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    Use the process list at the top to select and attach to a running process. The sidebar shows modules, threads, and memory maps.
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">2. Scan Memory</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    Enter a value in the scanner and click Scan. Refine with changed/unchanged scans until you narrow down the address.
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">3. Set Breakpoints &amp; Inspect</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    Right-click addresses to find what reads/writes them. Use the disassembler and debugger to understand code behavior.
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">4. Save &amp; Script</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    Add addresses to the Address Table, write Auto Assembler or Lua scripts, and export as Cheat Tables (.CT) for sharing.
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- ═══════════════════════════════════ -->
        <!-- Page 2: AI Operator Introduction   -->
        <!-- ═══════════════════════════════════ -->
        <StackPanel x:Name="Page2" Grid.Row="1" Visibility="Collapsed">
            <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,16"
                       Foreground="{DynamicResource PrimaryForeground}">
                The AI Operator chat panel is your intelligent assistant for memory analysis. It can help with tasks that would normally require deep expertise.
            </TextBlock>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">Natural Language Commands</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    Ask the AI to scan for values, set breakpoints, analyze code, or write scripts. Example: "Find the health value and freeze it at 999."
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">Tool Integration</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    The AI has access to 20+ tools including memory scanning, breakpoints, disassembly, Auto Assembler, Lua scripting, and pointer analysis.
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">Safety &amp; Permissions</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    Destructive operations (writing memory, injecting code) always require your approval. The AI follows a plan-then-execute workflow for complex tasks.
                </TextBlock>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AccentForeground}">Persistent Memory</TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="16,4,0,0" Foreground="{DynamicResource SecondaryForeground}">
                    The AI remembers discoveries across sessions — pointer paths, code patterns, and strategies are retained for future use.
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Navigation buttons -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <!-- Page indicators -->
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="Dot0" Width="8" Height="8" Fill="{DynamicResource AccentForeground}" Margin="0,0,6,0" />
                <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="{DynamicResource SecondaryForeground}" Margin="0,0,6,0" Opacity="0.4" />
                <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="{DynamicResource SecondaryForeground}" Opacity="0.4" />
            </StackPanel>

            <!-- Buttons (right-aligned) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SkipButton" Content="Skip" Padding="16,10" Margin="0,0,8,0"
                        Click="Skip_Click" FontSize="13"
                        Background="Transparent" Foreground="{DynamicResource SecondaryForeground}" BorderThickness="0" />
                <Button x:Name="BackButton" Content="Back" Padding="16,10" Margin="0,0,8,0"
                        Click="Back_Click" FontSize="13" Visibility="Collapsed" />
                <Button x:Name="NextButton" Content="Next" FontSize="14" FontWeight="SemiBold"
                        Padding="24,10" Click="Next_Click" IsDefault="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
    </Grid>
</Window>
